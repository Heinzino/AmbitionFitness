---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const pageTitle = "Group Sessions - Ambition Fitness Calgary";
const pageDescription = "Join our energizing group fitness classes in Calgary. Senior fitness, boot camps, and more. Build strength and community together.";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: true },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

const groupSessions = [
  {
    icon: "/img/vector-13.svg",
    iconAlt: "Senior Fitness Icon",
    iconStyles: "absolute w-[83.33%] h-[75.00%] top-[5.83%] left-0",
