        {
          src: "/img/vector-lightning.svg",
          alt: "Motivation icon",
          className:
            "absolute w-[75.03%] h-[83.36%] top-[4.16%] left-[8.32%]",
        },
      ],
    },
    title: "Motivation",
    description: "Group energy keeps you pushing harder",
  },
  {
    icon: {
      images: [
        {
          src: "/img/vector-calendar-1.svg",
