const scheduleData = {
  title: "Class Schedule",
  subtitle: "Join us for energizing group sessions throughout the week",
  days: [
    // {
    //   name: "Monday",
    //   classes: [
    //     { time: "6:00 AM", name: "Boot Camp", duration: "45 min" },
    //     { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
    //     { time: "5:30 PM", name: "Boot Camp", duration: "45 min" },
    //   ],
    // },
    // {
    //   name: "Tuesday",
    //   classes: [
    //     { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
    //     { time: "6:00 PM", name: "Boot Camp", duration: "45 min" },
    //   ],
    // },
    // {
    //   name: "Wednesday",
    //   classes: [
    //     { time: "6:00 AM", name: "Boot Camp", duration: "45 min" },
    //     { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
    //     { time: "5:30 PM", name: "Boot Camp", duration: "45 min" },
    //   ],
    // },
    // {
    //   name: "Thursday",
    //   classes: [
    //     { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
    //     { time: "6:00 PM", name: "Boot Camp", duration: "45 min" },
    //   ],
    // },
    // {
    //   name: "Friday",
    //   classes: [
    //     { time: "6:00 AM", name: "Boot Camp", duration: "45 min" },
    //     { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
    //   ],
    // },
    {
      name: "Saturday",
      classes: [
        { time: "9:00 AM", name: "Boot Camp", duration: "60 min" },
        // { time: "10:00 AM", name: "Senior Fitness", duration: "60 min" },
      ],
