---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const pageTitle = "Strength Training Calgary | Build Muscle & Get Stronger | Ambition Fitness";
const pageDescription = "Expert strength training in Calgary. Build muscle, increase power, and get stronger with personalized programs. Certified trainers, private facility, proven results. Start your strength journey today.";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

// Strength training benefits
const strengthBenefits = [
  {
    icon: "/img/vector-yellow.svg",
    title: "Build Lean Muscle Mass",
    description: "Develop a stronger, more defined physique with progressive resistance training tailored to your goals and experience level.",
  },
  {
    icon: "/img/vector-1-yellow.svg",
    title: "Increase Functional Strength",
    description: "Get stronger for everyday life—lifting, carrying, climbing stairs. Functional strength training makes daily activities easier and reduces injury risk.",
  },
  {
    icon: "/img/vector-3-yellow.svg",
    title: "Boost Your Metabolism",
    description: "Muscle tissue burns more calories at rest than fat. Building muscle increases your metabolism, helping with long-term weight management.",
  },
  {
    icon: "/img/vector-yellow.svg",
    title: "Improve Bone Density",
    description: "Resistance training strengthens bones and reduces osteoporosis risk. This is especially important as we age and for women's long-term health.",
  },
];

// What makes our strength program different
const programFeatures = [
  {
    title: "Progressive Overload Programming",
    description: "We systematically increase training stimulus to ensure continuous strength gains. No plateaus—just consistent progress toward your goals.",
  },
  {
    title: "Proper Form & Technique",
    description: "Learn correct lifting technique from day one. Proper form maximizes results and prevents injuries that can derail your progress.",
  },
  {
    title: "Periodized Training Plans",
    description: "Your program is strategically designed with phases for building strength, hypertrophy, and recovery to optimize long-term results.",
  },
  {
    title: "Nutrition for Strength",
    description: "Building muscle requires proper nutrition. We provide guidance on protein intake, meal timing, and eating to support your strength goals.",
  },
];

// Who strength training is for
const whoItsFor = [
  {
    title: "Beginners",
    description: "New to weight training? We'll teach you proper form and build a foundation of strength safely and effectively.",
  },
  {
    title: "Athletes",
    description: "Improve sport-specific power and performance with training designed for your athletic goals.",
  },
  {
    title: "Older Adults",
    description: "Maintain strength, independence, and quality of life. It's never too late to start building strength.",
  },
  {
    title: "Weight Loss Seekers",
    description: "Strength training preserves muscle while losing fat, creating a toned, defined physique rather than just a smaller one.",
  },
];

// FAQ Data
const faqData = [
  {
    question: "How often should I strength train?",
    answer: "For optimal results, we recommend strength training 2-4 times per week with adequate rest between sessions for the same muscle groups. During your consultation, we'll determine the right frequency based on your goals, schedule, and recovery capacity.",
  },
  {
    question: "Will strength training make me bulky?",
    answer: "Not unless that's your goal. Building significant muscle mass requires specific programming, high volume training, and often years of dedicated work. Most people develop a lean, toned physique. We customize your program based on your desired outcome.",
  },
  {
    question: "I'm a beginner. Is strength training safe for me?",
    answer: "Absolutely. Strength training is safe and beneficial for beginners when done with proper instruction. We start with foundational movements, teach correct form, and progress at a pace appropriate for your fitness level.",
  },
  {
    question: "What equipment do you have for strength training?",
    answer: "Our private facility is fully equipped with free weights (dumbbells, barbells, kettlebells), cable machines, resistance bands, and specialized equipment for compound and isolation exercises. You'll have everything needed for a complete strength program.",
  },
  {
    question: "How long until I see strength improvements?",
    answer: "Most beginners notice strength gains within 2-4 weeks as their nervous system adapts to lifting. Visible muscle changes typically appear around 6-8 weeks. Significant transformations occur over 3-6 months of consistent training.",
  },
  {
    question: "Can I combine strength training with cardio?",
    answer: "Yes. We can design a program that incorporates both strength and cardiovascular training based on your goals. The balance depends on whether you're prioritizing muscle building, fat loss, or overall fitness.",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/strength-training-calgary" />
    <LocalBusinessSchema />
    <!-- FAQ Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />
    <!-- Service Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Strength Training",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Ambition Fitness",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1440 52 St NE #130",
          "addressLocality": "Calgary",
          "addressRegion": "AB",
          "postalCode": "T2A 4T8",
          "addressCountry": "CA"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": "Calgary"
      },
      "description": "Expert strength training programs in Calgary. Build muscle, increase power, and improve functional strength with certified personal trainers."
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" /></noscript>
    <style>
      html { scroll-behavior: smooth; }
      body { overflow-x: hidden; overflow-y: auto; }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Hero Section -->
    <div class="relative w-full h-[500px] md:h-[650px] lg:h-[700px]">
      <img
        class="absolute top-0 left-0 w-full h-full object-cover"
        alt="Strength Training Calgary"
        src="/img/rectangle-6542.png"
      />

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-0 py-4 lg:py-0 lg:relative lg:inline-flex lg:gap-[221px] lg:top-[15px] lg:left-[360px] lg:w-auto">
          <a href="/">
            <img
              class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
              alt="Ambition Fitness Logo"
              src="/img/image-3-2.png"
            />
          </a>

          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>

          <div class="hidden md:flex items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]">
              {navigationLinks.map((link) => (
                <a
                  class={`relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`}
                  href={link.path}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-variable-collection-coloryellow rounded-[12.39px] w-full md:w-auto hover:opacity-90 transition-opacity">
              <span class="relative flex items-center justify-center w-fit font-16-medium font-[number:var(--16-medium-font-weight)] text-variable-collection-colorpriamry text-[length:var(--16-medium-font-size)] text-center tracking-[var(--16-medium-letter-spacing)] leading-[var(--16-medium-line-height)] whitespace-nowrap [font-style:var(--16-medium-font-style)]">
                Get in Touch
              </span>
              <img class="relative w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
            </a>
          </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden">
          <div class="flex flex-col items-center justify-center h-full px-4">
            <div class="flex flex-col items-center gap-8 w-full max-w-sm">
              {navigationLinks.map((link) => (
                <a
                  class={`text-2xl font-semibold [font-family:'Inter',Helvetica] ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`}
                  href={link.path}
                >
                  {link.label}
                </a>
              ))}
              <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-variable-collection-coloryellow rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                <span class="font-semibold text-variable-collection-colorpriamry text-lg [font-family:'Inter',Helvetica]">
                  Get in Touch
                </span>
                <img class="w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
              </a>
            </div>
          </div>
        </div>
      </nav>

      <!-- Hero Content -->
      <section class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 flex flex-col w-full max-w-[90%] md:max-w-[800px] items-center justify-center gap-6 md:gap-8 px-6 md:px-[60px] py-8 md:py-[50px] bg-[#0000000f] rounded-xl backdrop-blur-[17px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(17px)_brightness(100%)]">
        <h1 class="[font-family:'Montserrat',Helvetica] font-semibold text-transparent text-3xl md:text-5xl lg:text-[58px] text-center tracking-[0] leading-tight md:leading-[1.2]">
          <span class="text-[#fedf41]">Strength Training</span>
          <span class="text-[#f0f0f0]"> in Calgary</span>
        </h1>

        <p class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-xl lg:text-[22px] text-center tracking-[0] leading-relaxed md:leading-[35px] max-w-2xl">
          Build muscle, increase power, and get stronger with expert-designed programs. Personal coaching to help you lift with confidence and see real results.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-all hover:scale-105"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base">
              Start Building Strength
            </span>
            <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
          </a>
        </div>
      </section>
    </div>

    <!-- Main Content -->
    <main class="flex flex-col w-full items-center">

      <!-- Benefits of Strength Training -->
      <section class="flex flex-col w-full max-w-[1194px] items-center gap-12 md:gap-16 px-4 md:px-8 py-16 md:py-24 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              More than just lifting weights
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
            Benefits of Strength Training
          </h2>
          <p class="max-w-2xl [font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base md:text-lg leading-relaxed">
            Strength training does more than build muscle. It transforms your body composition, improves health markers, and enhances quality of life.
          </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 w-full">
          {strengthBenefits.map((benefit) => (
            <article class="flex flex-col items-start gap-4 p-6 md:p-8 bg-[#191919] rounded-xl border border-[#2e2e2e]">
              <div class="flex items-center gap-3">
                <div class="w-[40px] h-[40px] flex items-center justify-center bg-[#2a2a2a] rounded-lg">
                  <img src={benefit.icon} alt="" class="w-5 h-5" />
                </div>
                <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg md:text-xl">
                  {benefit.title}
                </h3>
              </div>
              <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>
      </section>

      <!-- Our Approach Section -->
      <div class="relative w-full py-16 md:py-24">
        <img class="absolute top-0 left-0 w-full h-full object-cover" alt="" src="/img/union-grey.svg" />

        <section class="relative flex flex-col w-full max-w-[1194px] items-center gap-12 md:gap-16 px-4 md:px-8 mx-auto z-10">
          <header class="flex flex-col items-center gap-4 text-center">
            <div class="inline-flex items-center gap-1.5">
              <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
                Science-backed methods
              </p>
              <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
            </div>
            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
              Our Strength Training Approach
            </h2>
          </header>

          <div class="flex flex-col lg:flex-row items-center gap-8 md:gap-12 lg:gap-16 w-full">
            <div class="w-full lg:w-1/2">
              <div
                class="w-full h-[400px] md:h-[500px] rounded-xl bg-cover bg-center"
                style="background-image: url('/img/personal-training-expertise.jpg')"
                role="img"
                aria-label="Strength training at Ambition Fitness Calgary"
              />
            </div>

            <div class="flex flex-col w-full lg:w-1/2 gap-6">
              {programFeatures.map((feature) => (
                <article class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-3 h-3 mt-2 bg-variable-collection-coloryellow rounded-full" />
                  <div>
                    <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg md:text-xl mb-2">
                      {feature.title}
                    </h3>
                    <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">
                      {feature.description}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-opacity"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base">
              Get Your Strength Program
            </span>
            <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
          </a>
        </section>
      </div>

      <!-- Who It's For Section -->
      <section class="flex flex-col w-full max-w-[1194px] items-center gap-12 px-4 md:px-8 py-16 md:py-24 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              For everyone
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
            Who Is Strength Training For?
          </h2>
          <p class="max-w-2xl [font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base md:text-lg leading-relaxed">
            Strength training benefits everyone—regardless of age, experience, or fitness level. Here's how we help different people achieve their goals.
          </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 w-full">
          {whoItsFor.map((item) => (
            <article class="flex items-start gap-4 p-6 bg-[#191919] rounded-xl border border-[#2e2e2e]">
              <div class="flex-shrink-0 w-3 h-3 mt-2 bg-variable-collection-coloryellow rounded-full" />
              <div>
                <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg mb-2">
                  {item.title}
                </h3>
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- FAQ Section -->
      <section id="faq" class="flex flex-col w-full max-w-[900px] items-center gap-8 md:gap-12 px-4 md:px-8 py-16 md:py-20 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              Questions answered
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] tracking-[0] leading-tight">
            Strength Training FAQ
          </h2>
        </header>

        <div class="flex flex-col gap-4 w-full">
          {faqData.map((faq) => (
            <details class="group bg-[#191919] rounded-xl border border-[#2e2e2e] overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 md:p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-lg text-left">
                  {faq.question}
                </h3>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-variable-collection-coloryellow transition-transform group-open:rotate-45">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6">
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-sm md:text-base leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA Section -->
      <section class="flex flex-col w-full max-w-[1010px] items-center justify-center gap-6 md:gap-10 p-8 md:p-[60px] mx-4 md:mx-auto mb-12 bg-variable-collection-coloryellow rounded-xl">
        <h2 class="[font-family:'Prompt',Helvetica] font-medium text-variable-collection-colorpriamry text-3xl md:text-5xl text-center tracking-[0] leading-tight md:leading-[53px]">
          Ready to Get Stronger?
        </h2>
        <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#222222] text-base md:text-xl text-center tracking-[0] leading-relaxed max-w-2xl">
          Book your free consultation and discover how our strength training programs can transform your body and performance.
        </p>
        <a
          href="/contact"
          class="inline-flex h-12 md:h-14 items-center justify-center gap-3 px-6 py-4 bg-variable-collection-colorpriamry rounded-xl hover:opacity-90 transition-opacity"
        >
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base">
            Start Your Strength Journey
          </span>
          <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-white.svg" />
        </a>
      </section>
    </main>

    <!-- Footer -->
    <footer class="w-full pt-12 pb-8 px-4 md:px-8 bg-black">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
            <p class="text-[#e4e4e4] text-sm">
              Calgary's trusted personal training facility. Transform your body and mind with personalized coaching.
            </p>
          </div>
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Services</h3>
            <div class="space-y-2">
              <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Personal Training</a>
              <a href="/memberships" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Memberships</a>
              <a href="/group-sessions" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Group Sessions</a>
            </div>
          </div>
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Service Area</h3>
            <div class="space-y-2">
              <a href="/personal-trainer-mayland-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Mayland Heights</a>
              <a href="/personal-trainer-meridian-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Meridian</a>
              <a href="/personal-trainer-raddison-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Raddison Heights</a>
