---
import '../styles/global.css';

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: true },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "#", isActive: false },
];

// Membership Benefits Data
const membershipBenefitsRow1 = [
  {
    icon: {
      images: [
        { src: "/img/vector-6.svg", alt: "Clock icon", className: "absolute w-[83.33%] h-[83.33%] top-[4.17%] left-[4.17%]" },
        { src: "/img/vector-1.svg", alt: "Clock hand", className: "absolute w-[16.67%] h-[33.33%] top-[20.83%] left-[45.83%]" },
      ],
    },
    title: "24/7 Access",
    description: "Train whenever it fits your schedule, day or night",
  },
  {
    icon: {
      images: [
        { src: "/img/vector-2.svg", alt: "People base", className: "absolute w-[58.33%] h-[25.00%] top-[58.33%] left-[4.17%]" },
        { src: "/img/vector-3.svg", alt: "Person left", className: "absolute w-[33.33%] h-[33.33%] top-[8.33%] left-[16.67%]" },
        { src: "/img/vector-4.svg", alt: "Person right small", className: "absolute w-[12.50%] h-[24.46%] top-[58.87%] left-[75.00%]" },
        { src: "/img/vector-5.svg", alt: "Person right large", className: "absolute w-[12.53%] h-[32.29%] top-[8.87%] left-[62.50%]" },
      ],
    },
    title: "Limited Spots",
    description: "Exclusive membership ensures it's never crowded",
  },
  {
    icon: {
      images: [
        { src: "/img/vector-6.svg", alt: "Face circle", className: "absolute w-[83.33%] h-[83.33%] top-[4.17%] left-[4.17%]" },
        { src: "/img/vector-7.svg", alt: "Smile", className: "absolute w-[33.33%] h-[8.33%] top-[54.17%] left-[29.17%]" },
        { src: "/img/vector-9.svg", alt: "Eye left", className: "absolute w-[4.55%] h-[3.64%] top-[33.33%] left-[33.33%]" },
        { src: "/img/vector-9.svg", alt: "Eye right", className: "absolute w-[4.55%] h-[3.64%] top-[33.33%] left-[58.33%]" },
      ],
    },
    title: "Non-Intimidating",
    description: "Welcoming environment for all fitness levels",
  },
];

const membershipBenefitsRow2 = [
  {
    icon: {
      images: [
        { src: "/img/vector-10.svg", alt: "Document with X", className: "absolute w-[66.67%] h-[83.35%] top-[4.16%] left-[12.50%]" },
      ],
    },
    title: "No Contracts",
    description: "Month-to-month flexibility, cancel anytime",
  },
  {
    icon: {
      images: [
        { src: "/img/vector-12.svg", alt: "Dollar sign S", className: "absolute w-[50.00%] h-[58.33%] top-[16.67%] left-[20.83%]" },
        { src: "/img/vector-11.svg", alt: "Dollar sign line", className: "absolute w-[8.33%] h-[83.33%] top-[4.17%] left-[45.83%]" },
      ],
    },
    title: "No Hidden Fees",
    description: "Simple, transparent pricing with everything included",
  },
  {
    icon: {
      images: [
        { src: "/img/vector-13.svg", alt: "Star decoration", className: "absolute w-[25.36%] h-[25.36%] top-[12.50%] left-[60.42%]" },
        { src: "/img/vector-14.svg", alt: "Key head", className: "absolute w-[40.00%] h-[40.00%] top-[4.17%] left-[43.33%]" },
        { src: "/img/vector-15.svg", alt: "Key body", className: "absolute w-[45.83%] h-[45.83%] top-[37.50%] left-[4.17%]" },
      ],
    },
    title: "Private Facility",
    description: "Secure access to a clean, well-maintained space",
  },
];

const membershipIncludes = [
  "Full access to all equipment and facilities",
  "Member-only events and challenges",
  "Clean, sanitized equipment daily",
  "Free parking and secure entry",
  "Showers and locker room access",
  "Friendly, supportive training environment",
];

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Memberships - Ambition Fitness</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Inter:wght@100..900&family=Prompt:wght@500&display=swap"
      rel="stylesheet"
    />
    <style>
      .font-montserrat { font-family: 'Montserrat', Helvetica, sans-serif; }
      .font-inter { font-family: 'Inter', Helvetica, sans-serif; }
      .font-prompt { font-family: 'Prompt', Helvetica, sans-serif; }

      html {
        scroll-behavior: smooth;
      }

      body {
        overflow-x: hidden;
        overflow-y: auto;
      }

      /* Prevent focus trap issues */
      * {
        outline-offset: 0;
      }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <div class="relative w-full min-h-[3600px]">

      <!-- Hero/Header Section with Background -->
      <div class="relative w-full h-[400px] md:h-[450px] lg:h-[458px] bg-[#14181f]">

        <!-- Decorative Line (Desktop only) -->
        <img
          class="hidden lg:block absolute top-11 left-[538px] w-px h-[33px]"
          alt="Line"
          src="/img/line-217.svg"
        />

        <!-- Navigation -->
        <nav class="absolute top-0 left-0 w-full z-50">
          <div class="flex items-center justify-between px-4 md:px-8 lg:px-0 py-4 lg:py-0 lg:relative lg:inline-flex lg:gap-[221px] lg:top-[15px] lg:left-[360px] lg:w-auto">
            <!-- Logo -->
            <a href="/" aria-label="Home">
              <img
                class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
                alt="Company Logo"
                src="/img/image-3-2-1.png"
              />
            </a>

            <!-- Hamburger Menu Button (Mobile Only) -->
            <button
              id="mobile-menu-btn"
              class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
              aria-label="Toggle mobile menu"
              aria-expanded="false"
            >
              <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
              <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
              <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
            </button>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
              <div
                class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]"
                aria-label="Main navigation"
              >
                {navigationLinks.map((item) =>
                  item.isActive ? (
                    <a
                      class="relative flex items-center justify-center w-fit font-inter font-medium text-[#fedf41] text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap"
                      href={item.path}
                      aria-current="page"
                    >
                      {item.label}
                    </a>
                  ) : (
                    <a
                      class="flex justify-center w-fit font-inter font-medium text-white text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap items-center relative hover:text-[#fedf41] transition-colors"
                      href={item.path}
                    >
                      {item.label}
                    </a>
                  )
                )}
              </div>

              <a
                href="/contact"
                class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-[#fedf41] rounded-[12.39px] cursor-pointer transition-opacity hover:opacity-90"
                aria-label="Get in Touch"
              >
                <span class="relative flex items-center justify-center w-fit font-montserrat font-medium text-[#14181f] text-sm md:text-base text-center tracking-[0] leading-[25.6px] whitespace-nowrap">
                  Get in Touch
                </span>
                <img
                  class="relative w-[18.33px] h-[11.41px] mr-[-0.77px]"
                  alt=""
                  src="/img/line-108-1.svg"
                  aria-hidden="true"
                />
              </a>
            </div>
          </div>

          <!-- Mobile Menu Overlay -->
          <div
            id="mobile-menu"
            class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden"
          >
            <div class="flex flex-col items-center justify-center h-full px-4">
              <div class="flex flex-col items-center gap-8 w-full max-w-sm">
                {navigationLinks.map((link) =>
                  link.isActive ? (
                    <a
                      class="text-[#fedf41] text-2xl font-semibold font-inter"
                      href={link.path}
                    >
                      {link.label}
                    </a>
                  ) : (
                    <a
                      class="text-white text-2xl font-semibold font-inter hover:text-[#fedf41] transition-colors"
                      href={link.path}
                    >
                      {link.label}
                    </a>
                  ),
                )}

                <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-[#fedf41] rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                  <span class="font-semibold text-[#14181f] text-lg font-inter">
                    Get in Touch
                  </span>
                  <img
                    class="w-[18.33px] h-[11.41px]"
                    alt="Line"
                    src="/img/line-108-1.svg"
                  />
                </a>
              </div>
            </div>
          </div>
        </nav>

        <!-- Hero Title Section -->
        <section class="flex flex-col items-center justify-center gap-6 md:gap-10 px-4 absolute top-[120px] md:top-[150px] lg:top-[203px] left-0 right-0 lg:left-[calc(50%_-_390px)] lg:right-auto lg:w-[780px]">
          <header class="flex flex-col items-center gap-4 md:gap-6 w-full">
            <div class="flex flex-col items-center gap-4 md:gap-[30px] w-full">
              <h1 class="font-montserrat font-semibold text-transparent text-3xl md:text-5xl lg:text-[65px] text-center tracking-[0] leading-[1.2] lg:leading-[78.7px]">
                <span class="text-[#f0f0f0]">Flexible </span>
                <span class="text-[#fedf41]">Memberships</span>
              </h1>
              <p class="opacity-[0.99] font-montserrat font-medium text-white text-base md:text-lg lg:text-[22px] text-center tracking-[0] leading-[1.6] lg:leading-[35.2px] px-4 md:px-0">
                Join a fitness community that puts you first
              </p>
            </div>
          </header>
        </section>
      </div>

      <!-- Background decorative elements (Desktop only) -->
      <img
        class="hidden lg:block absolute top-[1169px] left-0 w-[1920px] h-[787px]"
        alt="Union"
        src="/img/union.svg"
      />

      <img
        class="hidden lg:block absolute top-[1438px] left-[1009px] w-[559px] h-[354px]"
        alt="Rectangle"
        src="/img/rectangle-6544.png"
      />

      <!-- Membership Benefits Section -->
      <section class="flex flex-col items-start gap-6 md:gap-[30px] px-4 md:px-8 lg:px-0 py-12 md:py-16 lg:py-24 lg:absolute lg:top-[428px] lg:left-[360px] lg:w-[1194px]">
        <!-- First Row of Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 lg:gap-[30px] w-full">
          {membershipBenefitsRow1.map((benefit) => (
            <article
              class="flex flex-col items-center gap-4 md:gap-[22px] p-6 md:p-8 lg:p-[33px] bg-[#191919] rounded-xl shadow-[0px_1px_2px_#0000000d]"
            >
              <div class="relative w-12 h-12" role="img" aria-label={benefit.title}>
                {benefit.icon.images.map((image) => (
                  <img
                    class={image.className}
                    alt={image.alt}
                    src={image.src}
                  />
                ))}
              </div>

              <h3 class="font-montserrat font-medium text-neutral-50 text-xl md:text-2xl text-center tracking-[0] leading-6 whitespace-nowrap">
                {benefit.title}
              </h3>

              <p class="font-montserrat font-medium text-[#b3b3b3] text-sm md:text-base text-center tracking-[0] leading-6 md:leading-7">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>

        <!-- Second Row of Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 lg:gap-[30px] w-full">
          {membershipBenefitsRow2.map((benefit) => (
            <article
              class="flex flex-col items-center gap-4 md:gap-[22px] p-6 md:p-8 lg:p-[33px] bg-[#191919] rounded-xl shadow-[0px_1px_2px_#0000000d]"
            >
              <div class="relative w-12 h-12" role="img" aria-label={benefit.title}>
                {benefit.icon.images.map((image) => (
                  <img
                    class={image.className}
                    alt={image.alt}
                    src={image.src}
                  />
                ))}
              </div>

              <h3 class="font-montserrat font-medium text-neutral-50 text-xl md:text-2xl text-center tracking-[0] leading-6 whitespace-nowrap">
                {benefit.title}
              </h3>

              <p class="font-montserrat font-medium text-[#b3b3b3] text-sm md:text-base text-center tracking-[0] leading-6 md:leading-7">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>
      </section>

      <!-- Why Ambition Fitness Section -->
      <section
        class="flex flex-col items-start gap-8 md:gap-11 px-4 md:px-8 lg:px-[49px] py-8 md:py-10 mx-4 md:mx-8 lg:mx-auto lg:absolute lg:top-[1386px] lg:left-[calc(50%_-_595px)] lg:w-[748px] bg-black rounded-xl border border-solid border-[#363d49] shadow-[0px_1px_2px_#0000000d] mt-8 lg:mt-0"
        aria-labelledby="testimonials-heading"
      >
        <div class="flex flex-col items-start gap-3.5 w-full">
          <h2
            id="testimonials-heading"
            class="font-montserrat font-semibold text-neutral-50 text-2xl md:text-3xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px] w-full"
          >
            Why Ambition Fitness?
          </h2>

          <p class="font-montserrat font-medium text-white text-sm md:text-base text-center tracking-[0] leading-6">
            We're not your typical gym. Our limited membership model ensures
            you'll never fight for equipment or feel lost in the crowd.
            <br /><br />
            With 24/7 access, no contracts, and a supportive
            environment, you can focus on what matters most - your fitness
            journey.
          </p>
        </div>

        <div class="flex flex-col items-center justify-center gap-4 w-full">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[35px] py-[15px] w-full md:w-auto bg-[#fedf41] rounded-[1000px] cursor-pointer transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#fedf41] focus:ring-offset-2 focus:ring-offset-black"
            aria-label="Book an In-Person Tour"
          >
            <span class="font-montserrat font-medium text-[#14181f] text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
              Book an In-Person Tour
            </span>
            <img
              class="w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-1.svg"
              aria-hidden="true"
            />
          </a>

          <a
            href="#"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[35px] py-[15px] w-full md:w-auto bg-transparent border-2 border-[#fedf41] rounded-[1000px] cursor-pointer transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#fedf41] focus:ring-offset-2 focus:ring-offset-black"
            aria-label="Take a Virtual Tour"
          >
            <span class="font-montserrat font-medium text-[#fedf41] text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
              Take a Virtual Tour
            </span>
            <img
              class="w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-yellow.svg"
              aria-hidden="true"
            />
          </a>
        </div>
      </section>

      <!-- What's Included Section -->
      <section
        class="flex flex-col items-start gap-8 md:gap-12 px-4 md:px-8 lg:px-0 py-8 md:py-12 lg:py-20 lg:absolute lg:top-[2032px] lg:left-[calc(50%_-_367px)] lg:w-[734px] mt-12 lg:mt-0"
        aria-labelledby="whats-included-heading"
      >
        <div class="flex flex-col items-center w-full">
          <h2
            id="whats-included-heading"
            class="font-montserrat font-semibold text-neutral-50 text-2xl md:text-3xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]"
          >
            What's Included
          </h2>
        </div>

        <ul
          class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 w-full"
          role="list"
        >
          {membershipIncludes.map((benefit) => (
            <li class="flex items-start gap-3">
              <div
                class="flex flex-col w-6 h-7 items-start pt-1 pb-0 px-0"
                aria-hidden="true"
              >
                <div class="flex w-6 h-6 items-center justify-center bg-[#e2b91233] rounded-full">
                  <div class="w-3 h-3 bg-[#e2b912] rounded-full" />
                </div>
              </div>

              <p class="font-montserrat font-medium text-neutral-50 text-sm md:text-base tracking-[0] leading-6 md:leading-7">
                {benefit}
              </p>
            </li>
          ))}
        </ul>
      </section>

      <!-- Main Image -->
      <img
        class="hidden lg:block absolute top-[2450px] left-[360px] w-[1196px] h-[449px] object-cover"
        alt="Rectangle"
        src="/img/rectangle-6543.png"
      />

      <!-- Get Started Today Section -->
      <section class="flex flex-col items-center justify-center gap-6 md:gap-10 p-8 md:p-12 lg:p-[60px] mx-4 md:mx-8 lg:mx-auto lg:absolute lg:top-[3086px] lg:left-[calc(50%_-_505px)] lg:w-[1010px] bg-[#fedf41] rounded-xl mt-12 lg:mt-0">
        <div class="flex flex-col items-center justify-center gap-4 md:gap-5 w-full">
          <h2 class="font-prompt font-medium text-[#14181f] text-2xl md:text-3xl lg:text-5xl text-center tracking-[0] leading-[1.2] lg:leading-[53.3px]">
            Get Started Today!
          </h2>

          <p class="font-montserrat font-normal text-[#222222] text-base md:text-lg lg:text-[21px] text-center tracking-[0] leading-[1.5] lg:leading-[31.5px]">
            If you are ready to start living a healthy lifestyle, message me to
            get started! Everyone has a unique situation, and I'll strive to
            accommodate yours.
          </p>
        </div>

        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-[13px] px-6 py-4 bg-[#14181f] rounded-xl cursor-pointer transition-opacity hover:opacity-90 w-full md:w-auto"
          aria-label="Get Started Today"
        >
          <span class="font-montserrat font-medium text-white text-base tracking-[0] leading-6 whitespace-nowrap">
            Get Started Today
          </span>

          <img
            class="w-[18.33px] h-[11.41px]"
            alt=""
            src="/img/line-108-white.svg"
            aria-hidden="true"
          />
        </a>
      </section>

    </div>

    <!-- Footer -->
    <footer class="w-full pt-12 pb-8 px-4 md:px-8 bg-black relative z-10">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Logo and description -->
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
            <p class="text-[#e4e4e4] text-sm">
              Join a community that's transforming lives through evidence-based fitness strategies.
            </p>
          </div>
          <!-- Services -->
          <div>
            <h3 class="text-[#fedf41] font-semibold mb-4">Services</h3>
            <div class="space-y-2">
              <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Personal Training</a>
              <a href="/memberships" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Memberships</a>
              <a href="/group-sessions" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Group Sessions</a>
            </div>
          </div>
          <!-- Service Area -->
          <div>
            <h3 class="text-[#fedf41] font-semibold mb-4">Service Area</h3>
            <div class="space-y-2">
              <span class="block text-[#e4e4e4] text-sm">Mayland Heights</span>
              <span class="block text-[#e4e4e4] text-sm">Meridian</span>
              <span class="block text-[#e4e4e4] text-sm">Raddison Heights</span>
              <span class="block text-[#e4e4e4] text-sm">Bridgeland-Riverside</span>
            </div>
          </div>
          <!-- Company -->
          <div>
            <h3 class="text-[#fedf41] font-semibold mb-4">Company</h3>
            <div class="space-y-2">
              <a href="/" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Home</a>
              <a href="#" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Blog</a>
              <a href="/contact" class="block text-[#e4e4e4] text-sm hover:text-[#fedf41] transition-colors">Contact Us</a>
            </div>
          </div>
        </div>
        <!-- Copyright -->
        <div class="pt-8 border-t border-gray-700 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-[#919191] text-sm text-center md:text-left">© 2025 Ambition Fitness · All rights reserved.</p>
          <a href="https://www.instagram.com/ambitionfitness.ca" target="_blank" rel="noopener noreferrer">
            <img class="w-8 h-8" alt="Instagram" src="/img/instagram-icon.svg" />
          </a>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu JavaScript -->
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerLines = document.querySelectorAll('.hamburger-line');

      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');

          if (isOpen) {
            // Close menu
            mobileMenu.classList.add('hidden');
            document.body.style.overflow = 'auto';
            menuBtn.setAttribute('aria-expanded', 'false');

            // Reset hamburger to normal state
            hamburgerLines[0].style.transform = 'rotate(0) translateY(0)';
            hamburgerLines[1].style.opacity = '1';
            hamburgerLines[2].style.transform = 'rotate(0) translateY(0)';
          } else {
            // Open menu
            mobileMenu.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            menuBtn.setAttribute('aria-expanded', 'true');

            // Transform to X
            hamburgerLines[0].style.transform = 'rotate(45deg) translateY(9px)';
            hamburgerLines[1].style.opacity = '0';
            hamburgerLines[2].style.transform = 'rotate(-45deg) translateY(-9px)';
          }
        });

        // Close menu when clicking a link
        mobileMenu.addEventListener('click', (e) => {
          if (e.target.tagName === 'A') {
            mobileMenu.classList.add('hidden');
            document.body.style.overflow = 'auto';
            menuBtn.setAttribute('aria-expanded', 'false');

            // Reset hamburger
            hamburgerLines[0].style.transform = 'rotate(0) translateY(0)';
            hamburgerLines[1].style.opacity = '1';
            hamburgerLines[2].style.transform = 'rotate(0) translateY(0)';
          }
        });
      }
    </script>
  </body>
</html>