---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const pageTitle = "Gym Membership Calgary | Flexible Fitness Plans | Ambition Fitness";
const pageDescription = "Affordable gym memberships in Calgary with 24/7 access, no contracts, and premium equipment. Private facility, limited spots, never crowded. Book your free tour today.";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: true },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

// Membership Benefits Data
const membershipBenefitsRow1 = [
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="20" stroke="#fedf41" stroke-width="2.5"/>
      <path d="M24 12V24L30 30" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
    title: "24/7 Access",
    description: "Train whenever it fits your schedule, day or night",
  },
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="18" r="5" stroke="#fedf41" stroke-width="2.5"/>
      <path d="M4 35C4 31 8 28 12 28C16 28 20 31 20 35" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="36" cy="18" r="5" stroke="#fedf41" stroke-width="2.5"/>
      <path d="M28 35C28 31 32 28 36 28C40 28 44 31 44 35" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
    title: "Limited Spots",
    description: "Exclusive membership ensures it's never crowded",
  },
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="20" stroke="#fedf41" stroke-width="2.5"/>
      <circle cx="16" cy="20" r="2" fill="#fedf41"/>
      <circle cx="32" cy="20" r="2" fill="#fedf41"/>
      <path d="M16 30C16 30 19 34 24 34C29 34 32 30 32 30" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
    title: "Non-Intimidating",
    description: "Welcoming environment for all fitness levels",
  },
];

const membershipBenefitsRow2 = [
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="8" width="28" height="32" rx="2" stroke="#fedf41" stroke-width="2.5"/>
      <path d="M18 18L30 30M30 18L18 30" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
    title: "No Contracts",
    description: "Month-to-month flexibility, cancel anytime",
  },
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="20" stroke="#fedf41" stroke-width="2.5"/>
      <path d="M24 10V14M24 34V38" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M28 18C28 16 27 14 24 14C21 14 20 16 20 18C20 20 21 21 24 22C27 23 28 24 28 26C28 28 27 30 24 30C21 30 20 28 20 26" stroke="#fedf41" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
    title: "No Hidden Fees",
    description: "Simple, transparent pricing with everything included",
  },
  {
    iconSvg: `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M13 36C17.9706 36 22 31.9706 22 27C22 22.0294 17.9706 18 13 18C8.02944 18 4 22.0294 4 27C4 31.9706 8.02944 36 13 36Z" stroke="#fedf41" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M19.5 20.5L38 2" stroke="#fedf41" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M28 12L32 16C32.3739 16.3665 32.8765 16.5717 33.4 16.5717C33.9235 16.5717 34.4261 16.3665 34.8 16L38 12.8C38.3665 12.4261 38.5717 11.9235 38.5717 11.4C38.5717 10.8765 38.3665 10.3739 38 10L34 6" stroke="#fedf41" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    title: "Private Facility",
    description: "Secure access to a clean, well-maintained space",
  },
];

const membershipIncludes = [
  "Full access to all equipment and facilities",
  "Member-only events and challenges",
  "Clean, sanitized equipment daily",
  "Free parking and secure entry",
  "Showers and locker room access",
  "Friendly, supportive training environment",
];

// FAQ Data for Schema
const faqData = [
  {
    question: "How much is a gym membership in Calgary?",
    answer: "Gym membership costs in Calgary vary widely. At Ambition Fitness, we offer competitive rates for our premium private facility with 24/7 access. Contact us for current pricing and to find a plan that fits your budget.",
  },
  {
    question: "Do you offer month-to-month memberships?",
    answer: "Yes! We offer flexible month-to-month memberships with no long-term contracts. You can cancel anytime with no penalties or hidden fees.",
  },
  {
    question: "What's included in the membership?",
    answer: "Your membership includes 24/7 facility access, use of all equipment, free parking, and participation in member-only events and challenges.",
  },
  {
    question: "Can I freeze my membership?",
    answer: "Yes, we offer membership freezes for vacations, injuries, or other circumstances. Contact us to discuss your specific situation and we'll work with you to find a solution.",
  },
  {
    question: "Do you have a free trial or tour?",
    answer: "Absolutely! We encourage you to book a free in-person tour to see our facility and meet our team. You can also take a virtual tour on our website to get a preview of our space.",
  },
];

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/memberships" />
    <LocalBusinessSchema />
    <!-- FAQ Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload fonts for non-blocking loading -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" /></noscript>
    <style>
      .font-montserrat { font-family: 'Montserrat', Helvetica, sans-serif; }
      .font-inter { font-family: 'Inter', Helvetica, sans-serif; }
      .font-prompt { font-family: 'Prompt', Helvetica, sans-serif; }

      html {
        scroll-behavior: smooth;
      }

      body {
        overflow-x: hidden;
        overflow-y: auto;
      }

      /* Prevent focus trap issues */
      * {
        outline-offset: 0;
      }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <div class="relative w-full">

      <!-- Hero/Header Section with Background -->
      <div class="relative w-full h-[400px] md:h-[450px] lg:h-[458px] bg-[#14181f]">

        <!-- Decorative Line (Desktop only) -->
        <img
          class="hidden lg:block absolute top-11 left-[538px] w-px h-[33px]"
          alt="Line"
          src="/img/line-217.svg"
        />

        <!-- Navigation -->
        <nav class="absolute top-0 left-0 w-full z-50">
          <div class="flex items-center justify-between px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-[360px] py-4 lg:py-4 max-w-[1920px] mx-auto">
            <!-- Logo -->
            <a href="/" aria-label="Home">
              <img
                class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
                alt="Company Logo"
                src="/img/image-3-2-1.png"
              />
            </a>

            <!-- Hamburger Menu Button (Mobile Only) -->
            <button
              id="mobile-menu-btn"
              class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
              aria-label="Toggle mobile menu"
              aria-expanded="false"
            >
              <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
              <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
              <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
            </button>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-4 md:gap-6 lg:gap-10">
              <div
                class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center"
                aria-label="Main navigation"
              >
                {navigationLinks.map((item) =>
                  item.isActive ? (
                    <a
                      class="relative flex items-center justify-center w-fit font-inter font-medium text-[#fedf41] text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap"
                      href={item.path}
                      aria-current="page"
                    >
                      {item.label}
                    </a>
                  ) : (
                    <a
                      class="flex justify-center w-fit font-inter font-medium text-white text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap items-center relative hover:text-[#fedf41] transition-colors"
                      href={item.path}
                    >
                      {item.label}
                    </a>
                  )
                )}
              </div>

              <a
                href="/contact"
                class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] bg-[#fedf41] rounded-[12.39px] cursor-pointer transition-opacity hover:opacity-90"
                aria-label="Get in Touch"
              >
                <span class="flex items-center justify-center w-fit font-montserrat font-medium text-[#14181f] text-base text-center whitespace-nowrap">
                  Get in Touch
                </span>
                <img
                  class="w-[18.33px] h-[11.41px]"
                  alt=""
                  src="/img/line-108-1.svg"
                  aria-hidden="true"
                />
              </a>
            </div>
          </div>

          <!-- Mobile Menu Overlay -->
          <div
            id="mobile-menu"
            class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden"
          >
            <div class="flex flex-col items-center justify-center h-full px-4">
              <div class="flex flex-col items-center gap-8 w-full max-w-sm">
                {navigationLinks.map((link) =>
                  link.isActive ? (
                    <a
                      class="text-[#fedf41] text-2xl font-semibold font-inter"
                      href={link.path}
                    >
                      {link.label}
                    </a>
                  ) : (
                    <a
                      class="text-white text-2xl font-semibold font-inter hover:text-[#fedf41] transition-colors"
                      href={link.path}
                    >
                      {link.label}
                    </a>
                  ),
                )}

                <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-[#fedf41] rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                  <span class="font-semibold text-[#14181f] text-lg font-inter">
                    Get in Touch
                  </span>
                  <img
                    class="w-[18.33px] h-[11.41px]"
                    alt="Line"
                    src="/img/line-108-1.svg"
                  />
                </a>
              </div>
            </div>
          </div>
        </nav>

        <!-- Hero Title Section -->
        <section class="flex flex-col items-center justify-center gap-6 md:gap-10 px-4 absolute top-[150px] md:top-[170px] lg:top-[203px] left-0 right-0 lg:left-[calc(50%_-_390px)] lg:right-auto lg:w-[780px]">
          <header class="flex flex-col items-center gap-4 md:gap-6 w-full">
            <div class="flex flex-col items-center gap-4 md:gap-[30px] w-full">
              <h1 class="font-montserrat font-semibold text-transparent text-3xl md:text-5xl lg:text-[65px] text-center tracking-[0] leading-[1.2] lg:leading-[78.7px]">
                <span class="text-[#f0f0f0]">Flexible </span>
                <span class="text-[#fedf41]">Memberships</span>
              </h1>
              <p class="opacity-[0.99] font-montserrat font-medium text-white text-base md:text-lg lg:text-[22px] text-center tracking-[0] leading-[1.6] lg:leading-[35.2px] px-4 md:px-0">
                Join a fitness community that puts you first
              </p>
            </div>
          </header>
        </section>
      </div>

      <!-- Background decorative elements - hidden as they rely on absolute positioning -->
      <!-- These decorative elements are not compatible with responsive centered layout -->

      <!-- Membership Benefits Section -->
      <section class="flex flex-col items-start gap-6 md:gap-[30px] px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-0 py-12 md:py-16 lg:py-24 max-w-[1194px] mx-auto">
        <!-- First Row of Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 lg:gap-[30px] w-full">
          {membershipBenefitsRow1.map((benefit) => (
            <article
              class="flex flex-col items-center gap-4 md:gap-[22px] p-6 md:p-8 lg:p-[33px] bg-[#191919] rounded-xl shadow-[0px_1px_2px_#0000000d]"
            >
              <div class="w-12 h-12 flex items-center justify-center" set:html={benefit.iconSvg} />

              <h3 class="font-montserrat font-medium text-neutral-50 text-xl md:text-2xl text-center tracking-[0] leading-6 whitespace-nowrap">
                {benefit.title}
              </h3>

              <p class="font-montserrat font-medium text-[#b3b3b3] text-sm md:text-base text-center tracking-[0] leading-6 md:leading-7">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>

        <!-- Second Row of Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 lg:gap-[30px] w-full">
          {membershipBenefitsRow2.map((benefit) => (
            <article
              class="flex flex-col items-center gap-4 md:gap-[22px] p-6 md:p-8 lg:p-[33px] bg-[#191919] rounded-xl shadow-[0px_1px_2px_#0000000d]"
            >
              <div class="w-12 h-12 flex items-center justify-center" set:html={benefit.iconSvg} />

              <h3 class="font-montserrat font-medium text-neutral-50 text-xl md:text-2xl text-center tracking-[0] leading-6 whitespace-nowrap">
                {benefit.title}
              </h3>

              <p class="font-montserrat font-medium text-[#b3b3b3] text-sm md:text-base text-center tracking-[0] leading-6 md:leading-7">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>
      </section>

      <!-- Why Ambition Fitness Section -->
      <section
        class="flex flex-col items-start gap-8 md:gap-11 px-4 md:px-8 lg:px-[49px] py-8 md:py-10 mx-4 md:mx-8 lg:mx-auto max-w-[748px] bg-black rounded-xl border border-solid border-[#363d49] shadow-[0px_1px_2px_#0000000d] mt-8"
        aria-labelledby="testimonials-heading"
      >
        <div class="flex flex-col items-start gap-3.5 w-full">
          <h2
            id="testimonials-heading"
            class="font-montserrat font-semibold text-neutral-50 text-2xl md:text-3xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px] w-full"
          >
            Why Ambition Fitness?
          </h2>

          <p class="font-montserrat font-medium text-white text-sm md:text-base text-center tracking-[0] leading-6">
            We're not your typical gym. Our limited membership model ensures
            you'll never fight for equipment or feel lost in the crowd.
            <br /><br />
            With 24/7 access, no contracts, and a supportive
            environment, you can focus on what matters most - your fitness
            journey.
          </p>
        </div>

        <div class="flex flex-col items-center justify-center gap-4 w-full">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[35px] py-[15px] w-full md:w-auto bg-[#fedf41] rounded-[1000px] cursor-pointer transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#fedf41] focus:ring-offset-2 focus:ring-offset-black"
            aria-label="Book an In-Person Tour"
          >
            <span class="font-montserrat font-medium text-[#14181f] text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
              Book an In-Person Tour
            </span>
            <img
              class="w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-1.svg"
              aria-hidden="true"
            />
          </a>

          <a
            href="/virtual-tour"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[35px] py-[15px] w-full md:w-auto bg-transparent border-2 border-[#fedf41] rounded-[1000px] cursor-pointer transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#fedf41] focus:ring-offset-2 focus:ring-offset-black"
            aria-label="Take a Virtual Tour"
          >
            <span class="font-montserrat font-medium text-[#fedf41] text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
              Take a Virtual Tour
            </span>
            <img
              class="w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-yellow.svg"
              aria-hidden="true"
            />
          </a>
        </div>
      </section>

      <!-- Why Ambition Fitness Image (Mobile/Tablet) -->
      <img
        class="block lg:hidden w-full md:w-[500px] h-[250px] md:h-[300px] object-cover mx-auto px-4 md:px-8 rounded-lg my-8"
        alt="Ambition Fitness Training"
        src="/img/memberships-why-ambition.webp"
      />

      <!-- What's Included Section -->
      <section
        class="flex flex-col items-start gap-8 md:gap-12 px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-0 py-8 md:py-12 lg:py-20 max-w-[734px] mx-auto mt-12"
        aria-labelledby="whats-included-heading"
      >
        <div class="flex flex-col items-center w-full">
          <h2
            id="whats-included-heading"
            class="font-montserrat font-semibold text-neutral-50 text-2xl md:text-3xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]"
          >
            What's Included
          </h2>
        </div>

        <ul
          class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 w-full"
          role="list"
        >
          {membershipIncludes.map((benefit) => (
            <li class="flex items-start gap-3">
              <div
                class="flex flex-col w-6 h-7 items-start pt-1 pb-0 px-0"
                aria-hidden="true"
              >
                <div class="flex w-6 h-6 items-center justify-center bg-[#e2b91233] rounded-full">
                  <div class="w-3 h-3 bg-[#e2b912] rounded-full" />
                </div>
              </div>

              <p class="font-montserrat font-medium text-neutral-50 text-sm md:text-base tracking-[0] leading-6 md:leading-7">
                {benefit}
              </p>
            </li>
          ))}
        </ul>
      </section>

      <!-- Main Image -->
      <img
        class="w-full max-w-[1196px] h-[250px] md:h-[350px] lg:h-[449px] object-cover mx-auto px-4 md:px-8 lg:px-0 rounded-lg"
        alt="Ambition Fitness Facility"
        src="/img/memberships-main.jpg"
      />

      <!-- Membership FAQ Section -->
      <section id="faq" class="flex flex-col w-full max-w-[1010px] items-center gap-8 md:gap-12 px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-0 py-16 md:py-20 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="font-montserrat font-medium text-[#fedf41] text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              Common questions answered
            </p>
            <img
              class="w-16 md:w-[110.67px] h-[2.97px]"
              alt=""
              src="/img/rectangle-5-2.svg"
              role="presentation"
            />
          </div>
          <h2 class="font-montserrat font-semibold text-white text-2xl md:text-[35px] tracking-[0] leading-tight">
            Membership FAQ
          </h2>
        </header>

        <div class="flex flex-col gap-4 w-full">
          {faqData.map((faq, index) => (
            <details class="group bg-[#191919] rounded-xl border border-[#2e2e2e] overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 md:p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="font-montserrat font-medium text-white text-base md:text-lg text-left">
                  {faq.question}
                </h3>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-[#fedf41] transition-transform group-open:rotate-45">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6">
                <p class="font-montserrat font-normal text-[#e4e4e4] text-sm md:text-base leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </details>
          ))}
        </div>

        <p class="font-montserrat font-normal text-[#919191] text-sm text-center">
          Have more questions? <a href="/contact" class="text-[#fedf41] hover:underline">Contact us</a> or book a tour.
        </p>
      </section>

      <!-- Get Started Today Section -->
      <section class="flex flex-col items-center justify-center gap-6 md:gap-10 p-8 md:p-12 lg:p-[60px] mx-4 md:mx-8 lg:mx-auto max-w-[1010px] bg-[#fedf41] rounded-xl mt-4 mb-8 md:mb-12">
        <div class="flex flex-col items-center justify-center gap-4 md:gap-5 w-full">
          <h2 class="font-prompt font-medium text-[#14181f] text-2xl md:text-3xl lg:text-5xl text-center tracking-[0] leading-[1.2] lg:leading-[53.3px]">
            Get Started Today!
          </h2>

          <p class="font-montserrat font-normal text-[#222222] text-base md:text-lg lg:text-[21px] text-center tracking-[0] leading-[1.5] lg:leading-[31.5px]">
            If you are ready to start living a healthy lifestyle, message me to
            get started! Everyone has a unique situation, and I'll strive to
            accommodate yours.
          </p>
        </div>

        <a
