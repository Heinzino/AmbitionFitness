                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-[30px] relative self-stretch w-full flex-[0_0_auto]">
                {row.map((card, cardIndex) => (
                  <article
                    class={`flex flex-col w-full items-start justify-end gap-2.5 px-6 md:px-[25px] py-5 md:py-[22px] bg-[url(/img/frame-1984077586-4.png)] h-[250px] md:h-[382px] relative rounded-xl border-2 border-solid border-[#2e2e2e] bg-cover bg-[50%_50%] ${
                      card.hasImage ? "overflow-hidden" : ""
                    }`}
                  >
                    {card.hasImage && card.image && (
                      <img
                        class="absolute inset-0 w-full h-full object-cover"
                        alt={`${card.name} transformation`}
                        src={card.image}
                      />
                    )}

                    <div class="flex items-center justify-between relative self-stretch w-full flex-[0_0_auto] z-10">
                      <div class="inline-flex flex-col items-start justify-center gap-[7px] relative flex-[0_0_auto]">
                        <h3 class="relative w-fit mt-[-1.00px] [font-family:'Montserrat',Helvetica] font-semibold text-white text-base md:text-lg tracking-[0] leading-[28.8px] whitespace-nowrap">
                          {card.name}
                        </h3>

                        <div class="flex w-auto md:w-[122px] items-center gap-2.5 relative flex-[0_0_auto]">
                          <span class="relative w-fit mt-[-1.00px] [font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
                            Before
                          </span>

                          <img
                            class="relative w-[13.5px] h-[7.36px] object-cover"
                            alt="Arrow"
                            src="/img/line-218-11.svg"
                          />

                          <span class="relative w-fit mt-[-1.00px] [font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
                            After
                          </span>
                        </div>
                      </div>

                      <div
                        class="relative w-[7px] h-[7px] bg-variable-collection-coloryellow rounded-[3.5px]"
                        aria-hidden="true"
                      />
                    </div>
                  </article>
                ))}
              </div>
            </div>
            ))}
          </div>

          <button
            id="load-more-btn"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[35px] py-3 md:py-[15px] relative flex-[0_0_auto] bg-variable-collection-coloryellow rounded-[1000px] hover:opacity-90 transition-opacity"
            aria-label="Load more transformations"
          >
            <span class="relative w-fit mt-[-1.00px] [font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
              Load More
            </span>

            <img
              class="relative w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-2.svg"
              aria-hidden="true"
            />
          </button>
        </section>

        <!-- Call to Action Section -->
        <section class="flex flex-col w-full max-w-[1010px] items-center justify-center gap-6 md:gap-10 p-8 md:p-[60px] mx-4 md:mx-auto mt-12 md:mt-16 mb-8 md:mb-12 bg-variable-collection-coloryellow rounded-xl">
          <div class="flex flex-col items-start justify-center gap-4 md:gap-5 relative self-stretch w-full flex-[0_0_auto]">
            <h2 class="relative flex items-center justify-center self-stretch mt-[-1.00px] [font-family:'Prompt',Helvetica] font-medium text-variable-collection-colorpriamry text-3xl md:text-5xl text-center tracking-[0] leading-tight md:leading-[53.3px]">
              Get Started Today!
            </h2>

            <p class="relative self-stretch [font-family:'Montserrat',Helvetica] font-normal text-[#222222] text-base md:text-[21px] text-center tracking-[0] leading-relaxed md:leading-[31.5px]">
              If you are ready to start living a healthy lifestyle, message me to
              get started! Everyone has a unique situation, and I'll strive to
              accommodate yours.
            </p>
          </div>

          <button
            class="inline-flex h-12 md:h-14 items-center justify-center gap-3 md:gap-[13px] px-5 md:px-6 py-4 md:py-5 relative bg-variable-collection-colorpriamry rounded-xl overflow-hidden cursor-pointer transition-opacity hover:opacity-90"
            aria-label="Get Started Today"
          >
            <span class="relative w-fit [font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base tracking-[0] leading-6 whitespace-nowrap">
              Get Started Today
            </span>

            <img
              class="relative w-[18.33px] h-[11.41px] mr-[-0.77px]"
              alt=""
              src="/img/line-108-2.svg"
              aria-hidden="true"
            />
          </button>
        </section>
      </div>

      <!-- Simple inline footer with minimal spacing -->
      <footer class="w-full mt-12 pt-12 pb-8 px-4 md:px-8 bg-black">
        <div class="max-w-6xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
            <!-- Logo and description -->
            <div class="md:col-span-1">
              <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
              <p class="text-[#e4e4e4] text-sm">
                Join a community that's transforming lives through evidence-based fitness strategies.
              </p>
            </div>
            <!-- Services -->
            <div>
              <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Services</h3>
              <div class="space-y-2">
                <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Personal Training</a>
                <a href="#" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Group Classes</a>
                <a href="#" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Online Training</a>
              </div>
            </div>
            <!-- Service Area -->
            <div>
              <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Service Area</h3>
              <div class="space-y-2">
                <span class="block text-[#e4e4e4] text-sm">Mayland Heights</span>
                <span class="block text-[#e4e4e4] text-sm">Meridian</span>
                <span class="block text-[#e4e4e4] text-sm">Raddison Heights</span>
                <span class="block text-[#e4e4e4] text-sm">Bridgeland-Riverside</span>
              </div>
            </div>
            <!-- Company -->
            <div>
              <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Company</h3>
              <div class="space-y-2">
                <a href="/" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Home</a>
                <a href="#" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Blog</a>
                <a href="#" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Contact Us</a>
              </div>
            </div>
          </div>
          <!-- Copyright -->
          <div class="pt-8 border-t border-gray-700 flex justify-between items-center">
            <p class="text-[#919191] text-sm">© 2025 Ambition Fitness · All rights reserved.</p>
            <a href="https://www.instagram.com/ambitionfitness.ca" target="_blank" rel="noopener noreferrer">
              <img class="w-8 h-8" alt="Instagram" src="/img/instagram-icon.svg" />
            </a>
          </div>
        </div>
      </footer>

      <script>
        // Mobile Menu Toggle
        document.addEventListener('DOMContentLoaded', function() {
          const mobileMenuBtn = document.getElementById('mobile-menu-btn');
          const mobileMenu = document.getElementById('mobile-menu');
          const hamburgerLines = document.querySelectorAll('.hamburger-line');
          let isMenuOpen = false;

          if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', function() {
              isMenuOpen = !isMenuOpen;

              if (isMenuOpen) {
                // Show menu
                mobileMenu.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; // Prevent scrolling when menu is open

                // Animate hamburger to X
                hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
                hamburgerLines[1].style.opacity = '0';
                hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';

                mobileMenuBtn.setAttribute('aria-expanded', 'true');
              } else {
                // Hide menu
                mobileMenu.classList.add('hidden');
                document.body.style.overflow = ''; // Re-enable scrolling

                // Animate X back to hamburger
                hamburgerLines[0].style.transform = '';
                hamburgerLines[1].style.opacity = '1';
                hamburgerLines[2].style.transform = '';

                mobileMenuBtn.setAttribute('aria-expanded', 'false');
              }
            });

            // Close menu when clicking on a link
            const mobileMenuLinks = mobileMenu.querySelectorAll('a');
            mobileMenuLinks.forEach(link => {
              link.addEventListener('click', function() {
                isMenuOpen = false;
                mobileMenu.classList.add('hidden');
                document.body.style.overflow = '';
                hamburgerLines[0].style.transform = '';
                hamburgerLines[1].style.opacity = '1';
                hamburgerLines[2].style.transform = '';
                mobileMenuBtn.setAttribute('aria-expanded', 'false');
              });
            });
          }

          // Load More functionality for Client Transformations Gallery
          const loadMoreBtn = document.getElementById('load-more-btn');
          const transformationRows = document.querySelectorAll('.transformation-row');
          let visibleRows = 2; // Initially show 2 rows

          if (loadMoreBtn && transformationRows.length > 0) {
            // Hide button if all rows are already visible
            if (visibleRows >= transformationRows.length) {
              loadMoreBtn.style.display = 'none';
            }

            loadMoreBtn.addEventListener('click', function() {
              // Show the next row
              if (visibleRows < transformationRows.length) {
                transformationRows[visibleRows].classList.remove('hidden');
                visibleRows++;

                // Hide button if all rows are now visible
                if (visibleRows >= transformationRows.length) {
                  loadMoreBtn.style.display = 'none';
                }
              }
            });
          }
        });
      </script>
  </body>
</html>
