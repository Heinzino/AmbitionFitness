      <script>
        // Mobile Menu Toggle
        document.addEventListener('DOMContentLoaded', function() {
          const mobileMenuBtn = document.getElementById('mobile-menu-btn');
          const mobileMenu = document.getElementById('mobile-menu');
          const hamburgerLines = document.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;
          let isMenuOpen = false;

          if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', function() {
              isMenuOpen = !isMenuOpen;

              if (isMenuOpen) {
                // Show menu
                mobileMenu.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; // Prevent scrolling when menu is open

                // Animate hamburger to X
                hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
                hamburgerLines[1].style.opacity = '0';
                hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';

                mobileMenuBtn.setAttribute('aria-expanded', 'true');
              } else {
                // Hide menu
                mobileMenu.classList.add('hidden');
                document.body.style.overflow = ''; // Re-enable scrolling

                // Animate X back to hamburger
                hamburgerLines[0].style.transform = '';
                hamburgerLines[1].style.opacity = '1';
                hamburgerLines[2].style.transform = '';

                mobileMenuBtn.setAttribute('aria-expanded', 'false');
              }
            });

            // Close menu when clicking on a link
            const mobileMenuLinks = mobileMenu.querySelectorAll('a');
            mobileMenuLinks.forEach(link => {
              link.addEventListener('click', function() {
                isMenuOpen = false;
                mobileMenu.classList.add('hidden');
                document.body.style.overflow = '';
                hamburgerLines[0].style.transform = '';
                hamburgerLines[1].style.opacity = '1';
                hamburgerLines[2].style.transform = '';
                mobileMenuBtn.setAttribute('aria-expanded', 'false');
              });
            });
          }

          // Load More functionality for Client Transformations Gallery
          const loadMoreBtn = document.getElementById('load-more-btn');
          const transformationRows = document.querySelectorAll('.transformation-row');
          let visibleRows = 2; // Initially show 2 rows

          if (loadMoreBtn && transformationRows.length > 0) {
            // Hide button if all rows are already visible
            if (visibleRows >= transformationRows.length) {
              loadMoreBtn.style.display = 'none';
            }

            loadMoreBtn.addEventListener('click', function() {
              // Show the next row
              if (visibleRows < transformationRows.length) {
                transformationRows[visibleRows].classList.remove('hidden');
                visibleRows++;

                // Hide button if all rows are now visible
                if (visibleRows >= transformationRows.length) {
                  loadMoreBtn.style.display = 'none';
                }
              }
            });
          }
        });
      </script>
