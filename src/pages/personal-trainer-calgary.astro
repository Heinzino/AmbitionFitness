---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const pageTitle = "Personal Trainer Calgary | Certified Personal Training | Ambition Fitness";
const pageDescription = "Looking for a personal trainer in Calgary? Ambition Fitness offers certified personal training with proven results. Private facility, customized programs, and 24/7 support. Book your free consultation today.";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

// Benefits of hiring a personal trainer
const trainerBenefits = [
  {
    icon: "/img/vector-yellow.svg",
    title: "Customized Training Programs",
    description: "Every workout is designed specifically for your goals, fitness level, and schedule. No generic programs—just personalized training that gets results.",
  },
  {
    icon: "/img/vector-1-yellow.svg",
    title: "Expert Guidance & Form Correction",
    description: "Learn proper technique from day one to maximize results and prevent injuries. Our certified trainers ensure every movement is performed safely and effectively.",
  },
  {
    icon: "/img/vector-3-yellow.svg",
    title: "Accountability & Motivation",
    description: "Stay on track with scheduled sessions and a dedicated trainer who knows your goals. We provide 24/7 support to keep you motivated between sessions.",
  },
  {
    icon: "/img/vector-yellow.svg",
    title: "Faster, Measurable Results",
    description: "With expert programming and consistent guidance, you'll see progress faster than training alone. Track your improvements with regular assessments.",
  },
];

// What sets us apart
const whyChooseUs = [
  {
    title: "Private Training Facility",
    description: "Train in a comfortable, judgment-free environment. Our private studio means no waiting for equipment and full attention from your trainer.",
  },
  {
    title: "Certified & Experienced Trainers",
    description: "Our trainers hold nationally recognized certifications and have years of experience helping Calgary residents achieve their fitness goals.",
  },
  {
    title: "Proven Track Record",
    description: "View our transformation gallery to see real results from real Calgary clients. Our methods work—the proof is in the transformations.",
  },
  {
    title: "Flexible Scheduling",
    description: "Early mornings, evenings, and weekends available. We work around your busy schedule to make fitness fit your life.",
  },
];

// Testimonials - using actual client images
const testimonials = [
  {
    name: "Jameela D",
    text: "It has been over a year since I started training with Guil at Ambition Fitness. I've struggled with weight and diet for over a decade and being able to look at myself in the mirror and be happy has been a massive accomplishment. When he says 24/7 support, he means it.",
    image: "/img/frame-1984077583-4.png",
  },
  {
    name: "Kelly Heath",
    text: "Ambition Fitness Weight Loss Program has delivered outstanding results. The progress that is visible on a weekly basis provides me great motivation to continue on and achieve my weight loss goal.",
    image: "/img/image-11-8.png",
  },
  {
    name: "Rebecca Rosaasen",
    text: "He is amazing! He helped me reach my goals and up my self esteem to the point I didn't know originally existed! He is very flexible with scheduling, and always has a smiling face when you walk through the door!",
    image: "/img/image-11-9.png",
  },
];

// FAQ Data
const faqData = [
  {
    question: "How do I find the best personal trainer in Calgary?",
    answer: "Look for certified trainers with proven results, positive client testimonials, and a training style that matches your personality. At Ambition Fitness, we offer a free consultation so you can meet your potential trainer and see our facility before committing.",
  },
  {
    question: "What certifications should a Calgary personal trainer have?",
    answer: "Reputable personal trainers should hold certifications from recognized organizations like CSEP, NSCA, ACE, or NASM. Our trainers at Ambition Fitness are fully certified and continuously update their education to provide the best training methods.",
  },
  {
    question: "How much does a personal trainer cost in Calgary?",
    answer: "Personal training rates in Calgary typically range from $50-$150 per session depending on trainer experience and session length. At Ambition Fitness, we offer flexible packages to fit different budgets. Contact us for a free consultation to discuss pricing options.",
  },
  {
    question: "How often should I meet with my personal trainer?",
    answer: "Most clients see optimal results with 2-4 sessions per week. During your initial assessment, we'll recommend the right frequency based on your goals, schedule, and current fitness level. We also provide guidance for workouts on your own.",
  },
  {
    question: "What should I expect in my first personal training session?",
    answer: "Your first session includes a comprehensive assessment of your current fitness level, discussion of your goals, and an introduction to proper exercise form. We'll create a roadmap for your fitness journey and start with exercises appropriate for your level.",
  },
  {
    question: "Do you offer online personal training in Calgary?",
    answer: "Yes! We offer online personal training for clients who prefer to work out from home or have busy schedules. You'll receive customized programming, video guidance, and regular check-ins with your trainer.",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/personal-trainer-calgary" />
    <LocalBusinessSchema />
    <!-- FAQ Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />
    <!-- Service Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Personal Training",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Ambition Fitness",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1440 52 St NE #130",
          "addressLocality": "Calgary",
          "addressRegion": "AB",
          "postalCode": "T2A 4T8",
          "addressCountry": "CA"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": "Calgary",
        "containedIn": "Alberta"
      },
      "description": "Certified personal training services in Calgary. Customized programs for weight loss, strength training, and body transformation.",
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "CAD"
        }
      }
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" /></noscript>
    <style>
      html { scroll-behavior: smooth; }
      body { overflow-x: hidden; overflow-y: auto; }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Hero Section -->
    <div class="relative w-full h-[500px] md:h-[650px] lg:h-[700px]">
      <img
        class="absolute top-0 left-0 w-full h-full object-cover"
        alt="Personal Trainer Calgary"
        src="/img/rectangle-6542.png"
      />

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-[360px] py-4 lg:py-4 max-w-[1920px] mx-auto">
          <a href="/">
            <img
              class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
              alt="Ambition Fitness Logo"
              src="/img/image-3-2.png"
            />
          </a>

          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>

          <div class="hidden md:flex items-center gap-4 md:gap-6 lg:gap-10">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center">
              {navigationLinks.map((link) => (
                <a
                  class={`relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`}
                  href={link.path}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] bg-variable-collection-coloryellow rounded-[12.39px] hover:opacity-90 transition-opacity">
              <span class="flex items-center justify-center w-fit [font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-base text-center whitespace-nowrap">
                Get in Touch
              </span>
              <img class="relative w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
            </a>
          </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden">
          <div class="flex flex-col items-center justify-center h-full px-4">
            <div class="flex flex-col items-center gap-8 w-full max-w-sm">
              {navigationLinks.map((link) => (
                <a
                  class={`text-2xl font-semibold [font-family:'Inter',Helvetica] ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`}
                  href={link.path}
                >
                  {link.label}
                </a>
              ))}
              <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-variable-collection-coloryellow rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                <span class="font-semibold text-variable-collection-colorpriamry text-lg [font-family:'Inter',Helvetica]">
                  Get in Touch
                </span>
                <img class="w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
              </a>
            </div>
          </div>
        </div>
      </nav>

      <!-- Hero Content -->
      <section class="absolute top-[55%] md:top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 flex flex-col w-full max-w-[90%] md:max-w-[800px] items-center justify-center gap-6 md:gap-8 px-6 md:px-[60px] py-8 md:py-[50px] bg-[#0000000f] rounded-xl backdrop-blur-[17px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(17px)_brightness(100%)]">
        <h1 class="[font-family:'Montserrat',Helvetica] font-semibold text-transparent text-3xl md:text-5xl lg:text-[60px] text-center tracking-[0] leading-tight md:leading-[1.2]">
          <span class="text-[#f0f0f0]">Find Your Perfect </span>
          <span class="text-[#fedf41]">Personal Trainer</span>
          <span class="text-[#f0f0f0]"> in Calgary</span>
        </h1>

        <p class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-xl lg:text-[22px] text-center tracking-[0] leading-relaxed md:leading-[35px] max-w-2xl">
          Certified personal trainers dedicated to helping you achieve your fitness goals. Private facility, customized programs, and proven results.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-all hover:scale-105"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base">
              Book Free Consultation
            </span>
            <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
          </a>
          <a
            href="/personal-training"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 border-2 border-white rounded-full hover:bg-white hover:text-black transition-all"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base hover:text-black">
              View Our Programs
            </span>
          </a>
        </div>
      </section>
    </div>

    <!-- Main Content -->
    <main class="flex flex-col w-full items-center">

      <!-- Why Hire a Personal Trainer Section -->
      <section class="flex flex-col w-full max-w-[1194px] items-center gap-12 md:gap-16 px-4 md:px-8 py-16 md:py-24 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              Accelerate your fitness journey
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
            Why Hire a Personal Trainer in Calgary?
          </h2>
          <p class="max-w-2xl [font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base md:text-lg leading-relaxed">
            Working with a certified personal trainer is the fastest path to achieving your fitness goals. Here's what you gain with professional guidance.
          </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 w-full">
          {trainerBenefits.map((benefit) => (
            <article class="flex flex-col items-start gap-4 p-6 md:p-8 bg-[#191919] rounded-xl border border-[#2e2e2e]">
              <div class="flex items-center gap-3">
                <div class="w-[40px] h-[40px] flex items-center justify-center bg-[#2a2a2a] rounded-lg">
                  <img src={benefit.icon} alt="" class="w-5 h-5" />
                </div>
                <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg md:text-xl">
                  {benefit.title}
                </h3>
              </div>
              <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">
                {benefit.description}
              </p>
            </article>
          ))}
        </div>
      </section>

      <!-- Why Choose Ambition Fitness Section -->
      <div class="relative w-full py-16 md:py-24">
        <img class="absolute top-0 left-0 w-full h-full object-cover" alt="" src="/img/union-grey.svg" />

        <section class="relative flex flex-col w-full max-w-[1194px] items-center gap-12 md:gap-16 px-4 md:px-8 mx-auto z-10">
          <header class="flex flex-col items-center gap-4 text-center">
            <div class="inline-flex items-center gap-1.5">
              <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
                Calgary's trusted fitness partner
              </p>
              <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
            </div>
            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
              Why Choose Ambition Fitness?
            </h2>
          </header>

          <div class="flex flex-col lg:flex-row items-center gap-8 md:gap-12 lg:gap-16 w-full">
            <div class="w-full lg:w-1/2">
              <div
                class="w-full h-[400px] md:h-[500px] rounded-xl bg-cover bg-center"
                style="background-image: url('/img/personal-training-expertise.jpg')"
                role="img"
                aria-label="Personal training at Ambition Fitness Calgary"
              />
            </div>

            <div class="flex flex-col w-full lg:w-1/2 gap-6">
              {whyChooseUs.map((item) => (
                <article class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-3 h-3 mt-2 bg-variable-collection-coloryellow rounded-full" />
                  <div>
                    <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg md:text-xl mb-2">
                      {item.title}
                    </h3>
                    <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">
                      {item.description}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-opacity"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base">
              Schedule Your Free Consultation
            </span>
            <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
          </a>
        </section>
      </div>

      <!-- Testimonials Section -->
      <section class="flex flex-col w-full max-w-[1194px] items-center gap-12 px-4 md:px-8 py-16 md:py-24 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              Real results from real Calgary clients
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] lg:text-[45px] tracking-[0] leading-tight">
            What Our Clients Say
          </h2>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 w-full">
          {testimonials.map((testimonial) => (
            <article class="flex flex-col gap-6 p-6 md:p-8 bg-[#191919] rounded-xl border border-[#2e2e2e]">
              <div class="flex items-center gap-4">
                <div
                  class="w-16 h-16 rounded-full bg-cover bg-center"
                  style={`background-image: url(${testimonial.image})`}
                />
                <div>
                  <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg">
                    {testimonial.name}
                  </h3>
                  <p class="[font-family:'Montserrat',Helvetica] font-normal text-variable-collection-coloryellow text-sm">
                    Verified Client
                  </p>
                </div>
              </div>
              <blockquote class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">
                "{testimonial.text}"
              </blockquote>
            </article>
          ))}
        </div>

        <a
          href="/personal-training#transformations"
          class="inline-flex items-center justify-center gap-2.5 text-variable-collection-coloryellow hover:underline"
        >
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-base">
            View All Client Transformations
          </span>
          <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" style="filter: brightness(0) saturate(100%) invert(89%) sepia(36%) saturate(1025%) hue-rotate(358deg) brightness(103%) contrast(99%);" />
        </a>
      </section>

      <!-- FAQ Section -->
      <section id="faq" class="flex flex-col w-full max-w-[900px] items-center gap-8 md:gap-12 px-4 md:px-8 py-16 md:py-20 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <div class="inline-flex items-center gap-1.5">
            <p class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-sm md:text-[15px] tracking-[0.45px] leading-[24px]">
              Common questions answered
            </p>
            <img class="w-16 md:w-[110.67px] h-[2.97px]" alt="" src="/img/rectangle-5-2.svg" />
          </div>
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] tracking-[0] leading-tight">
            Personal Trainer Calgary FAQ
          </h2>
        </header>

        <div class="flex flex-col gap-4 w-full">
          {faqData.map((faq) => (
            <details class="group bg-[#191919] rounded-xl border border-[#2e2e2e] overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 md:p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-lg text-left">
                  {faq.question}
                </h3>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-variable-collection-coloryellow transition-transform group-open:rotate-45">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6">
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-sm md:text-base leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA Section -->
      <section class="flex flex-col w-full max-w-[1010px] items-center justify-center gap-6 md:gap-10 p-8 md:p-[60px] mx-4 md:mx-auto mb-12 bg-variable-collection-coloryellow rounded-xl">
        <h2 class="[font-family:'Prompt',Helvetica] font-medium text-variable-collection-colorpriamry text-3xl md:text-5xl text-center tracking-[0] leading-tight md:leading-[53px]">
          Ready to Start Your Fitness Journey?
        </h2>
        <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#222222] text-base md:text-xl text-center tracking-[0] leading-relaxed max-w-2xl">
          Book your free consultation today and discover how our certified Calgary personal trainers can help you achieve your goals faster.
        </p>
        <a
          href="/contact"
          class="inline-flex h-12 md:h-14 items-center justify-center gap-3 px-6 py-4 bg-variable-collection-colorpriamry rounded-xl hover:opacity-90 transition-opacity"
        >
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base">
            Book Your Free Consultation
          </span>
          <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-white.svg" />
        </a>
      </section>
    </main>

    <!-- Footer -->
    <footer class="w-full pt-12 pb-8 px-4 md:px-8 bg-black">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
