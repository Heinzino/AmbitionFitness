---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { HeroSection } from '../sections/HeroSection';
import { NewsletterSection } from '../sections/NewsletterSection';
import { HeaderSection } from '../sections/HeaderSection';
import { WhyChooseUsSection } from '../sections/WhyChooseUsSection';
import { ClientTransformationsSection } from '../sections/ClientTransformationsSection';
import { FeatureProductsSection } from '../sections/FeatureProductsSection';
import { TestimonialsSection } from '../sections/TestimonialsSection';
import { FindUsNearYouSection } from '../sections/FindUsNearYouSection';

const pageTitle = "Ambition Fitness - Calgary's Elite Personal Training Services";
const pageDescription = "Calgary's elite personal training facility. Private 1-on-1 coaching, proven transformations, and state-of-the-art equipment. Book your free consultation today!";

const whyChooseUsFeatures = [
  {
    id: 1,
    icon: "/img/vector.svg",
    iconType: "vector",
    title: "Elite Equipment",
    description: "State-of-the-art training equipment for maximum performance",
  },
  {
    id: 2,
    icon: "/img/football-leader-man-svgrepo-com-1.svg",
    iconType: "image",
    title: "Expert Coaches",
    description: "Certified trainers with years of professional experience",
  },
  {
    id: 3,
    icon: "/img/goal-svgrepo-com-1.svg",
    iconType: "image",
    title: "Proven Results",
    description: "Track record of transforming hundreds of clients",
  },
  {
    id: 4,
    icon: "/img/plans-planning-svgrepo-com-1.svg",
    iconType: "image",
    title: "Personalized Plans",
    description: "Custom training programs tailored to your goals",
  },
];

const navigationLinks = [
  { label: "Home", path: "/", isActive: true },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/" />
    <LocalBusinessSchema />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload the critical Montserrat font files for LCP text -->
    <link rel="preload" href="https://fonts.gstatic.com/s/montserrat/v29/JTUSjIg1_i6t8kCHKm459WlhyyTh89Y.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://fonts.gstatic.com/s/montserrat/v29/JTUHjIg1_i6t8kCHKm4532VJOt5-QNFgpCtr6Hw5aXp-p7K4KLg.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Load fonts asynchronously -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" /></noscript>
    <!-- Meyer reset CSS is now inlined in global.css -->
    <style>
      /* Critical CSS for LCP - ensures text renders immediately with fallback fonts */
      body {
        overflow-x: hidden;
        overflow-y: auto;
      }
      /* Font fallback system to minimize CLS */
      @font-face {
        font-family: 'Montserrat-fallback';
        src: local('Arial');
        ascent-override: 84.5%;
        descent-override: 22%;
        line-gap-override: 0%;
        size-adjust: 112.5%;
      }
      /* Font fallbacks to prevent render delay while web fonts load */
      .font-montserrat, [class*="font-family:'Montserrat'"], [style*="Montserrat"] {
        font-family: 'Montserrat', 'Montserrat-fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      /* Ensure hero text is visible immediately with minimal CLS */
      h1, h2, h3, .hero-heading {
        font-family: 'Montserrat', 'Montserrat-fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        font-display: swap;
      }
      /* Prevent layout shift on yellow highlighted text */
      .text-\[\#fedf41\], .text-variable-collection-coloryellow {
        font-family: 'Montserrat', 'Montserrat-fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
    </style>
  </head>
  <body>
    <div
      class="bg-black overflow-x-hidden w-full lg:min-w-[1920px] min-h-screen lg:min-h-[8100px] relative"
      data-model-id="1:24"
    >
      <!-- Background decorative images - hidden on mobile for performance -->
      <img
        class="hidden lg:block absolute top-[2772px] h-[1418px] left-0 w-full"
        alt=""
        src="/img/union.svg"
        loading="lazy"
        aria-hidden="true"
      />

      <img
        class="hidden lg:block absolute top-[5881px] h-[904px] left-0 w-full"
        alt=""
        src="/img/union-1.svg"
        loading="lazy"
        aria-hidden="true"
      />

      <picture>
        <source
          srcset="/img/hero-bg-sm.webp 640w, /img/hero-bg-md.webp 1024w, /img/hero-bg-lg.webp 1920w"
          sizes="100vw"
          type="image/webp"
        />
        <img
          class="absolute top-0 left-0 w-full h-[400px] md:h-[600px] lg:h-[1011px] object-cover"
          alt="Ambition Fitness gym interior"
          src="/img/hero-bg-md.webp"
          srcset="/img/hero-bg-sm.webp 640w, /img/hero-bg-md.webp 1024w, /img/hero-bg-lg.webp 1920w"
          sizes="100vw"
          width="1920"
          height="1010"
          fetchpriority="high"
        />
      </picture>

      <div class="hidden lg:block absolute top-[166px] left-[314px] w-[817px] h-[522px] bg-[#000000b2] rounded-[408.5px/261px] blur-[107px]" />

      <img
        class="hidden lg:block absolute top-11 left-[538px] w-px h-[33px]"
        alt="Line"
        src="/img/line-217.svg"
      />

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-0 py-4 lg:py-0 lg:relative lg:inline-flex lg:gap-[221px] lg:top-[15px] lg:left-[360px] lg:w-auto bg-black/50 md:bg-transparent">
          <!-- Logo -->
          <img
            class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
            alt="Ambition Fitness Logo"
            src="/img/image-3-2.png"
          />

          <!-- Hamburger Menu Button (Mobile Only) -->
          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]">
              {navigationLinks.map((link) =>
                link.isActive ? (
                  <a
                    class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-variable-collection-coloryellow text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ) : (
                  <a
                    class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-white text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap hover:text-variable-collection-coloryellow transition-colors"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ),
              )}
            </div>

            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-variable-collection-coloryellow rounded-[12.39px] w-full md:w-auto hover:opacity-90 transition-opacity">
              <span class="relative flex items-center justify-center w-fit font-16-medium font-[number:var(--16-medium-font-weight)] text-variable-collection-colorpriamry text-[length:var(--16-medium-font-size)] text-center tracking-[var(--16-medium-letter-spacing)] leading-[var(--16-medium-line-height)] whitespace-nowrap [font-style:var(--16-medium-font-style)]">
                Get in Touch
              </span>

              <img
                class="relative w-[18.33px] h-[11.41px]"
                alt="Line"
                src="/img/line-108-1.svg"
              />
            </a>
          </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div
          id="mobile-menu"
          class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden"
        >
          <div class="flex flex-col items-center justify-center h-full px-4">
            <div class="flex flex-col items-center gap-8 w-full max-w-sm">
              {navigationLinks.map((link) =>
                link.isActive ? (
                  <a
                    class="text-variable-collection-coloryellow text-2xl font-semibold [font-family:'Inter',Helvetica]"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ) : (
                  <a
                    class="text-white text-2xl font-semibold [font-family:'Inter',Helvetica] hover:text-variable-collection-coloryellow transition-colors"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ),
              )}

              <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-variable-collection-coloryellow rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                <span class="font-semibold text-variable-collection-colorpriamry text-lg [font-family:'Inter',Helvetica]">
                  Get in Touch
                </span>
                <img
                  class="w-[18.33px] h-[11.41px]"
                  alt="Line"
                  src="/img/line-108-1.svg"
                />
              </a>
            </div>
          </div>
        </div>
      </nav>

      <main class="flex flex-col w-full relative">
        <HeroSection />
        <NewsletterSection />
        <HeaderSection />

        <!-- Why Choose Us Section - Responsive -->
        <section class="flex flex-col items-center gap-8 md:gap-10 px-4 md:px-8 py-12 md:py-16 lg:py-0 w-full lg:w-[1200px] mx-auto lg:mx-0 relative lg:absolute lg:top-[2240px] lg:left-[calc(50.00%_-_600px)]">
          <div class="flex flex-col items-center gap-2.5 w-full max-w-[559px]">
            <div class="inline-flex items-center gap-1.5">
              <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-[15px] text-center tracking-[0.45px] leading-[24.0px] whitespace-nowrap">
                Our Unique Edge
              </span>

              <img
                class="w-[110.67px] h-[2.97px]"
                alt=""
                src="/img/rectangle-5-4.svg"
                aria-hidden="true"
              />
            </div>

            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-3xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-tight">
              Why Choose Us
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-[1200px]">
            {whyChooseUsFeatures.map((feature) => (
              <article
                class="flex flex-col items-center gap-[30px] p-[25px] bg-[#191919] rounded-xl"
              >
                {feature.iconType === "vector" ? (
                  <div class="relative w-[50px] h-[50px] aspect-[1]">
                    <img
                      class="absolute w-[94.34%] h-[94.34%] top-[2.83%] left-[2.83%]"
                      alt={feature.title}
                      src={feature.icon}
                    />
                  </div>
                ) : (
                  <img
                    class="w-[50px] h-[50px] aspect-[1]"
                    alt={feature.title}
                    src={feature.icon}
                  />
                )}

                <div class="flex flex-col items-start justify-center gap-2 w-full">
                  <h3 class="w-full [font-family:'Montserrat',Helvetica] font-medium text-[#e4e4e4] text-lg md:text-[21px] text-center tracking-[0] leading-[31.5px]">
                    {feature.title}
                  </h3>

                  <p class="w-full opacity-80 [font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base text-center tracking-[0] leading-6">
                    {feature.description}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <WhyChooseUsSection />
        <ClientTransformationsSection />
        <TestimonialsSection />
        <FindUsNearYouSection />
        <FeatureProductsSection />
      </main>
    </div>

    <!-- Simple inline footer with minimal spacing -->
    <footer class="w-full mt-0 pt-12 pb-8 px-4 md:px-8 bg-black">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Logo and description -->
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
            <p class="text-[#e4e4e4] text-sm">
              Join a community that's transforming lives through evidence-based fitness strategies.
            </p>
          </div>
          <!-- Services -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Services</h3>
            <div class="space-y-2">
              <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Personal Training</a>
              <a href="/memberships" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Memberships</a>
              <a href="/group-sessions" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Group Sessions</a>
            </div>
          </div>
          <!-- Service Area -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Service Area</h3>
            <div class="space-y-2">
              <span class="block text-[#e4e4e4] text-sm">Mayland Heights</span>
              <span class="block text-[#e4e4e4] text-sm">Meridian</span>
              <span class="block text-[#e4e4e4] text-sm">Raddison Heights</span>
              <span class="block text-[#e4e4e4] text-sm">Bridgeland-Riverside</span>
            </div>
          </div>
          <!-- Company -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Company</h3>
            <div class="space-y-2">
              <a href="/" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Home</a>
              <a href="#" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Blog</a>
              <a href="/contact" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Contact Us</a>
            </div>
          </div>
        </div>
        <!-- Copyright -->
        <div class="pt-8 border-t border-gray-700 flex justify-between items-center">
          <p class="text-[#919191] text-sm">© 2025 Ambition Fitness · All rights reserved.</p>
          <a href="https://www.instagram.com/ambitionfitness.ca" target="_blank" rel="noopener noreferrer">
            <img class="w-8 h-8" alt="Instagram" src="/img/instagram-icon.svg" />
          </a>
        </div>
      </div>
    </footer>

    <script>
      // Mobile Menu Toggle
      document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerLines = document.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;
        let isMenuOpen = false;

        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', function() {
            isMenuOpen = !isMenuOpen;

            if (isMenuOpen) {
              // Show menu
              mobileMenu.classList.remove('hidden');
              document.body.style.overflow = 'hidden'; // Prevent scrolling when menu is open

              // Animate hamburger to X
              hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
              hamburgerLines[1].style.opacity = '0';
              hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';

              mobileMenuBtn.setAttribute('aria-expanded', 'true');
            } else {
              // Hide menu
              mobileMenu.classList.add('hidden');
              document.body.style.overflow = ''; // Re-enable scrolling

              // Animate X back to hamburger
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';

              mobileMenuBtn.setAttribute('aria-expanded', 'false');
            }
          });

          // Close menu when clicking on a link
          const mobileMenuLinks = mobileMenu.querySelectorAll('a');
          mobileMenuLinks.forEach(link => {
            link.addEventListener('click', function() {
              isMenuOpen = false;
              mobileMenu.classList.add('hidden');
              document.body.style.overflow = '';
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
              mobileMenuBtn.setAttribute('aria-expanded', 'false');
            });
          });
        }
      });
    </script>
  </body>
</html>
