---
import '../styles/global.css';
import { HeroSection } from '../sections/HeroSection';
import { NewsletterSection } from '../sections/NewsletterSection';
import { HeaderSection } from '../sections/HeaderSection';
import { WhyChooseUsSection } from '../sections/WhyChooseUsSection';
import { ClientTransformationsSection } from '../sections/ClientTransformationsSection';
import { FeatureProductsSection } from '../sections/FeatureProductsSection';
import { TestimonialsSection } from '../sections/TestimonialsSection';
import { FooterSection } from '../sections/FooterSection';
import { FindUsNearYouSection } from '../sections/FindUsNearYouSection';

const whyChooseUsFeatures = [
  {
    id: 1,
    icon: "/img/vector.svg",
    iconType: "vector",
    title: "Elite Equipment",
    description: "State-of-the-art training equipment for maximum performance",
  },
  {
    id: 2,
    icon: "/img/football-leader-man-svgrepo-com-1.svg",
    iconType: "image",
    title: "Expert Coaches",
    description: "Certified trainers with years of professional experience",
  },
  {
    id: 3,
    icon: "/img/goal-svgrepo-com-1.svg",
    iconType: "image",
    title: "Proven Results",
    description: "Track record of transforming hundreds of clients",
  },
  {
    id: 4,
    icon: "/img/plans-planning-svgrepo-com-1.svg",
    iconType: "image",
    title: "Personalized Plans",
    description: "Custom training programs tailored to your goals",
  },
];

const navigationLinks = [
  { label: "Home", path: "/", isActive: true },
  { label: "Personal Training", path: "#", isActive: false },
  { label: "Memberships", path: "#", isActive: false },
  { label: "Group Sessions", path: "#", isActive: false },
  { label: "Virtual Tour", path: "#", isActive: false },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Ambition Fitness - Calgary's Elite Personal Training Services</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css?family=Inter:500,var(--16-medium-font-weight)|Montserrat:400,500,700,600|Prompt:500" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/meyer-reset/2.0/reset.min.css" rel="stylesheet" />
  </head>
  <body>
    <div
      class="bg-black overflow-hidden w-full lg:min-w-[1920px] min-h-screen lg:min-h-[8650px] relative"
      data-model-id="1:24"
    >
      <!-- Background decorative images - hidden on mobile for performance -->
      <img
        class="hidden lg:block absolute top-[2772px] h-[1418px] left-0 w-full"
        alt="Union"
        src="/img/union.svg"
      />

      <img
        class="hidden lg:block absolute top-[5881px] h-[904px] left-0 w-full"
        alt="Union"
        src="/img/union-1.svg"
      />

      <img
        class="absolute top-0 left-0 w-full h-[400px] md:h-[600px] lg:h-[1011px] object-cover"
        alt="Image"
        src="/img/image.png"
      />

      <div class="hidden lg:block absolute top-[166px] left-[314px] w-[817px] h-[522px] bg-[#000000b2] rounded-[408.5px/261px] blur-[107px]" />

      <img
        class="hidden lg:block absolute top-11 left-[538px] w-px h-[33px]"
        alt="Line"
        src="/img/line-217.svg"
      />

      <!-- Responsive Navigation -->
      <nav class="flex flex-col md:flex-row lg:inline-flex items-center gap-4 lg:gap-[221px] px-4 md:px-8 lg:px-0 py-4 lg:py-0 relative lg:absolute lg:top-[15px] lg:left-[360px] w-full lg:w-auto z-10">
        <img
          class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative"
          alt="Image"
          src="/img/image-3-2.png"
        />

        <div class="flex flex-col md:flex-row items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
          <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]">
            {navigationLinks.map((link) =>
              link.isActive ? (
                <a
                  class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-variable-collection-coloryellow text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap"
                  href={link.path}
                >
                  {link.label}
                </a>
              ) : (
                <a
                  class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-white text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap hover:text-variable-collection-coloryellow transition-colors"
                  href={link.path}
                >
                  {link.label}
                </a>
              ),
            )}
          </div>

          <button class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-variable-collection-coloryellow rounded-[12.39px] w-full md:w-auto">
            <span class="relative flex items-center justify-center w-fit font-16-medium font-[number:var(--16-medium-font-weight)] text-variable-collection-colorpriamry text-[length:var(--16-medium-font-size)] text-center tracking-[var(--16-medium-letter-spacing)] leading-[var(--16-medium-line-height)] whitespace-nowrap [font-style:var(--16-medium-font-style)]">
              Get in Touch
            </span>

            <img
              class="relative w-[18.33px] h-[11.41px]"
              alt="Line"
              src="/img/line-108-1.svg"
            />
          </button>
        </div>
      </nav>

      <div class="flex flex-col w-full">
        <HeroSection client:load />
        <NewsletterSection client:load />
        <HeaderSection client:load />

        <!-- Why Choose Us Section - Responsive -->
        <section class="flex flex-col items-center gap-8 md:gap-10 px-4 md:px-8 py-12 md:py-16 lg:py-0 w-full lg:w-[1200px] mx-auto lg:mx-0 relative lg:absolute lg:top-[2240px] lg:left-[calc(50.00%_-_600px)]">
          <div class="flex flex-col items-center gap-2.5 w-full max-w-[559px]">
            <div class="inline-flex items-center gap-1.5">
              <h3 class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-coloryellow text-[15px] text-center tracking-[0.45px] leading-[24.0px] whitespace-nowrap">
                Our Unique Edge
              </h3>

              <img
                class="w-[110.67px] h-[2.97px]"
                alt="Rectangle"
                src="/img/rectangle-5-4.svg"
              />
            </div>

            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-3xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-tight">
              Why Choose Us
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-[1200px]">
            {whyChooseUsFeatures.map((feature) => (
              <article
                class="flex flex-col items-center gap-[30px] p-[25px] bg-[#191919] rounded-xl"
              >
                {feature.iconType === "vector" ? (
                  <div class="relative w-[50px] h-[50px] aspect-[1]">
                    <img
                      class="absolute w-[94.34%] h-[94.34%] top-[2.83%] left-[2.83%]"
                      alt={feature.title}
                      src={feature.icon}
                    />
                  </div>
                ) : (
                  <img
                    class="w-[50px] h-[50px] aspect-[1]"
                    alt={feature.title}
                    src={feature.icon}
                  />
                )}

                <div class="flex flex-col items-start justify-center gap-2 w-full">
                  <h4 class="w-full [font-family:'Montserrat',Helvetica] font-medium text-[#e4e4e4] text-lg md:text-[21px] text-center tracking-[0] leading-[31.5px]">
                    {feature.title}
                  </h4>

                  <p class="w-full opacity-80 [font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base text-center tracking-[0] leading-6">
                    {feature.description}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <WhyChooseUsSection client:load />
        <ClientTransformationsSection client:load />
        <TestimonialsSection client:load />
        <FindUsNearYouSection client:load />
        <FeatureProductsSection client:load />
        <FooterSection client:load />
      </div>
    </div>
  </body>
</html>
