---
import '../../styles/global.css';
import SEO from '../../components/SEO.astro';
import LocalBusinessSchema from '../../components/LocalBusinessSchema.astro';

const pageTitle = "Fitness Blog | Personal Training Tips & Advice | Ambition Fitness Calgary";
const pageDescription = "Expert fitness tips, workout guides, and nutrition advice from Calgary's top personal trainers. Learn how to achieve your fitness goals with Ambition Fitness.";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

const blogPosts = [
  {
    slug: "benefits-of-strength-training",
    title: "10 Benefits of Strength Training Beyond Building Muscle",
    excerpt: "Strength training offers far more than bigger muscles. Discover the surprising health benefits that make it essential for everyone.",
    date: "November 28, 2024",
    readTime: "7 min read",
    image: "/img/rectangle-6543.png",
    category: "Strength Training",
  },
  {
    slug: "beginners-guide-to-the-gym",
    title: "A Beginner's Complete Guide to the Gym",
    excerpt: "Feeling intimidated by the gym? This comprehensive guide covers everything you need to know to start your fitness journey with confidence.",
    date: "November 22, 2024",
    readTime: "8 min read",
    image: "/img/rectangle-6542.png",
    category: "Beginners",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/blog" />
    <LocalBusinessSchema />
    <style>
      .blog-card:hover .blog-image {
        transform: scale(1.05);
      }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Hero Section -->
    <div class="relative w-full h-[400px] md:h-[450px]">
      <img
        class="absolute top-0 left-0 w-full h-full object-cover"
        alt="Fitness Blog"
        src="/img/rectangle-6542.png"
      />
      <div class="absolute inset-0 bg-black/60"></div>

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-12 xl:px-16 2xl:px-[360px] py-4 lg:py-4 max-w-[1920px] mx-auto">
          <a href="/">
            <img
              class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
              alt="Ambition Fitness Logo"
              src="/img/image-3-2.png"
            />
          </a>

          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>

          <div class="hidden md:flex items-center gap-4 md:gap-6 lg:gap-10">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center">
              {navigationLinks.map((link) => (
                <a
                  class={`relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`}
                  href={link.path}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] bg-variable-collection-coloryellow rounded-[12.39px] hover:opacity-90 transition-opacity">
              <span class="flex items-center justify-center w-fit [font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-base text-center whitespace-nowrap">
                Get in Touch
              </span>
              <img class="relative w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
            </a>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="fixed inset-0 bg-black/95 z-40 hidden md:hidden">
          <div class="flex flex-col items-center justify-center h-full gap-8">
            {navigationLinks.map((link) => (
              <a
                class={`text-2xl font-medium ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white'}`}
                href={link.path}
              >
                {link.label}
              </a>
            ))}
            <a href="/contact" class="mt-4 inline-flex items-center justify-center gap-2 px-8 py-4 bg-variable-collection-coloryellow rounded-full">
              <span class="font-medium text-black">Get in Touch</span>
            </a>
          </div>
        </div>
      </nav>

      <!-- Hero Content -->
      <div class="absolute top-[55%] md:top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center">
        <h1 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-3xl md:text-5xl lg:text-6xl mb-4">
          Fitness <span class="text-[#fedf41]">Blog</span>
        </h1>
        <p class="[font-family:'Montserrat',Helvetica] font-medium text-white/90 text-lg md:text-xl max-w-2xl mx-auto px-4">
          Expert tips, guides, and insights from Calgary's top personal trainers
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex flex-col w-full items-center">
      <!-- Blog Posts Grid -->
      <section class="w-full max-w-[1194px] px-4 md:px-8 py-16 md:py-24 mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
          {blogPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card group block bg-[#191919] rounded-xl overflow-hidden border border-[#2e2e2e] hover:border-variable-collection-coloryellow transition-all duration-300">
              <div class="relative h-[200px] md:h-[240px] overflow-hidden">
                <img
                  src={post.image}
                  alt={post.title}
                  class="blog-image w-full h-full object-cover transition-transform duration-500"
                />
                <span class="absolute top-4 left-4 bg-variable-collection-coloryellow text-black text-xs font-semibold px-3 py-1 rounded-full">
                  {post.category}
                </span>
              </div>
              <div class="p-6 md:p-8">
                <div class="flex items-center gap-4 text-[#919191] text-sm mb-3">
                  <span>{post.date}</span>
                  <span>•</span>
                  <span>{post.readTime}</span>
                </div>
                <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-xl md:text-2xl mb-3 group-hover:text-variable-collection-coloryellow transition-colors">
                  {post.title}
                </h2>
                <p class="[font-family:'Montserrat',Helvetica] text-[#e4e4e4] text-base leading-relaxed">
                  {post.excerpt}
                </p>
                <div class="mt-4 flex items-center gap-2 text-variable-collection-coloryellow font-medium">
                  Read More
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- CTA Section -->
      <section class="w-full bg-[#191919] py-16 md:py-20">
        <div class="max-w-[1194px] mx-auto px-4 md:px-8 text-center">
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-4xl mb-4">
            Ready to Start Your <span class="text-variable-collection-coloryellow">Fitness Journey?</span>
          </h2>
          <p class="[font-family:'Montserrat',Helvetica] text-[#e4e4e4] text-lg mb-8 max-w-2xl mx-auto">
            Book a free consultation with one of our certified personal trainers and take the first step toward your goals.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-all hover:scale-105"
          >
            <span class="[font-family:'Montserrat',Helvetica] font-medium text-black text-base">
              Book Free Consultation
            </span>
            <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
          </a>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="w-full mt-12 pt-12 pb-8 px-4 md:px-8 bg-black">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Logo and description -->
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
            <p class="text-[#e4e4e4] text-sm">
              Calgary's premier personal training facility. Customized programs, expert trainers, and proven results.
            </p>
            <div class="space-y-2 text-sm mt-4">
              <a href="https://maps.google.com/?q=1440+52+St+NE+%23130,+Calgary,+AB+T2A+4T8" target="_blank" rel="noopener noreferrer" class="flex items-start gap-2 text-[#e4e4e4] hover:text-variable-collection-coloryellow transition-colors">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
                <span>1440 52 St NE #130<br />Calgary, AB T2A 4T8</span>
              </a>
              <a href="tel:825-479-2977" class="flex items-center gap-2 text-[#e4e4e4] hover:text-variable-collection-coloryellow transition-colors">
                <svg class="w-4 h-4 flex-shrink-0 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                <span>825-479-2977</span>
              </a>
              <a href="mailto:info@ambitionfitness.ca" class="flex items-center gap-2 text-[#e4e4e4] hover:text-variable-collection-coloryellow transition-colors break-all">
                <svg class="w-4 h-4 flex-shrink-0 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span>info@ambitionfitness.ca</span>
              </a>
            </div>
          </div>
          <!-- Services -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Services</h3>
            <div class="space-y-2">
              <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Personal Training</a>
              <a href="/memberships" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Memberships</a>
              <a href="/group-sessions" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Group Sessions</a>
            </div>
          </div>
          <!-- Service Area -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Service Area</h3>
            <div class="space-y-2">
              <a href="/personal-trainer-mayland-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Mayland Heights</a>
              <a href="/personal-trainer-meridian-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Meridian</a>
              <a href="/personal-trainer-raddison-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Raddison Heights</a>
              <a href="/personal-trainer-bridgeland-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Bridgeland-Riverside</a>
              <a href="/personal-trainer-renfrew-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Renfrew</a>
            </div>
          </div>
          <!-- Company -->
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Company</h3>
            <div class="space-y-2">
              <a href="/" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Home</a>
              <a href="/blog" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Blog</a>
              <a href="/contact" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Contact Us</a>
              <a href="/privacy-policy" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Privacy Policy</a>
              <a href="/terms-of-service" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Terms of Service</a>
            </div>
          </div>
        </div>
        <!-- Copyright -->
        <div class="pt-8 border-t border-gray-700 flex justify-between items-center">
          <p class="text-[#919191] text-sm">© 2025 Ambition Fitness · All rights reserved.</p>
          <a href="https://www.instagram.com/ambitionfitness.ca" target="_blank" rel="noopener noreferrer">
            <img class="w-8 h-8" alt="Instagram" src="/img/instagram-icon.svg" />
          </a>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerLines = document.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;

        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.contains('hidden');
            mobileMenu.classList.toggle('hidden');
            mobileMenuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

            if (isOpen) {
              hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
              hamburgerLines[1].style.opacity = '0';
              hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';
            } else {
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
            }
          });

          mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
              mobileMenu.classList.add('hidden');
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
            });
          });
        }
      });
    </script>
  </body>
</html>
