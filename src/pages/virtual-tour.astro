            width="100%"
            height="575"
            style="width: 100%; height: 575px; border: none; max-width: 100%; border-radius: 12px;"
            frameborder="0"
            allow="xr-spatial-tracking; gyroscope; accelerometer; fullscreen"
            scrolling="no"
            allowfullscreen="true"
            src="https://kuula.co/share/collection/7Y3kG?logo=1&info=1&fs=1&vr=0&sd=1&thumbs=1">
            <p>Your browser doesn't support iframes. <a href="https://kuula.co/share/collection/7Y3kG?logo=1&info=1&fs=1&vr=0&sd=1&thumbs=1" target="_blank" rel="noopener noreferrer">View the virtual tour directly on Kuula</a></p>
