---
import '../styles/global.css';

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: true },
];

const facilityFeatures = [
  "State-of-the-art cardio equipment",
  "Full range of free weights and machines",
  "Dedicated stretching and mobility area",
  "Clean, well-maintained locker rooms",
  "Climate-controlled environment",
  "Private training areas",
  "Ample parking",
  "24/7 secure access",
];

const differentiators = [
  {
    title: "Never Crowded",
    description: "Our limited membership model ensures you always have access to the equipment you need, when you need it. No more waiting, no more frustration.",
  },
  {
    title: "Always Clean",
    description: "We take pride in maintaining a spotless facility. Equipment is sanitized daily, and our space is always ready for your workout.",
  },
  {
    title: "Non-Intimidating",
    description: "We've created a welcoming environment where everyone feels comfortable, regardless of fitness level or experience. This is your space to grow.",
  },
  {
    title: "Private Access",
    description: "Secure 24/7 access means you can train on your schedule. Early morning or late night, we're here when you need us.",
  },
];

const galleryImages = [
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/1-0001.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/1-0001.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Gym Entrance" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0004-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0004-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Training Area" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0019-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0019-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Weight Training Zone" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0025-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0025-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Cardio Equipment" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/unnamed.jpg/:/rs=w:1160,h:840", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/unnamed.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Functional Training Area" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0067-HDR.jpg/:/rs=w:1280,h:854", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0067-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Free Weights Section" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0058-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0058-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Stretching Area" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0106-HDR.jpg/:/rs=w:1280,h:854", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0106-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Machine Training Zone" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0172-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0172-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Personal Training Area" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0148-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0148-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Equipment Detail" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0070-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0070-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Training Floor" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0064-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0064-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Gym Overview" },
  { src: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0073-HDR.jpg/:/rs=w:1280,h:853", thumb: "//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/IMG_0073-HDR.jpg/:/rs=w:70,h:70,cg:true,m/cr=w:70,h:70,a:cc", alt: "Fitness Equipment" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Virtual Tour - Ambition Fitness Calgary</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Take a virtual tour of Ambition Fitness Calgary. Explore our state-of-the-art private training facility from the comfort of your home." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css?family=Inter:400,500,600,700|Montserrat:400,500,600,700|Prompt:500" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/meyer-reset/2.0/reset.min.css" rel="stylesheet" />
    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        overflow-x: hidden;
        overflow-y: auto;
      }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Hero Background Section -->
    <div class="relative w-full h-[400px] md:h-[450px] lg:h-[458px] bg-[#14181f]">
      <!-- Decorative Line -->
      <img
        class="hidden lg:block absolute top-11 left-[538px] w-px h-[33px]"
        alt="Line"
        src="/img/line-217.svg"
      />

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-0 py-4 lg:py-0 lg:relative lg:inline-flex lg:gap-[221px] lg:top-[15px] lg:left-[360px] lg:w-auto">
          <!-- Logo -->
          <a href="/" aria-label="Home">
            <img
              class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50"
              alt="Ambition Fitness Logo"
              src="/img/image-3-2.png"
            />
          </a>

          <!-- Hamburger Menu Button (Mobile Only) -->
          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]">
              {navigationLinks.map((link) =>
                link.isActive ? (
                  <a
                    class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-[#fedf41] text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ) : (
                  <a
                    class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-white text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap hover:text-[#fedf41] transition-colors"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                )
              )}
            </div>

            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-[#fedf41] rounded-[12.39px] w-full md:w-auto hover:opacity-90 transition-opacity">
              <span class="relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-black text-base text-center tracking-[0] leading-6 whitespace-nowrap">
                Get in Touch
              </span>

              <img
                class="relative w-[18.33px] h-[11.41px]"
                alt="Arrow"
                src="/img/line-108-3.svg"
              />
            </a>
          </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div
          id="mobile-menu"
          class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden"
        >
          <div class="flex flex-col items-center justify-center h-full px-4">
            <div class="flex flex-col items-center gap-8 w-full max-w-sm">
              {navigationLinks.map((link) =>
                link.isActive ? (
                  <a
                    class="text-[#fedf41] text-2xl font-semibold [font-family:'Inter',Helvetica]"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                ) : (
                  <a
                    class="text-white text-2xl font-semibold [font-family:'Inter',Helvetica] hover:text-[#fedf41] transition-colors"
                    href={link.path}
                  >
                    {link.label}
                  </a>
                )
              )}

              <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-[#fedf41] rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                <span class="font-semibold text-black text-lg [font-family:'Inter',Helvetica]">
                  Get in Touch
                </span>
                <img
                  class="w-[18.33px] h-[11.41px]"
                  alt="Arrow"
                  src="/img/line-108-3.svg"
                />
              </a>
            </div>
          </div>
        </div>
      </nav>

      <!-- Hero Section -->
      <section class="flex flex-col items-center justify-center gap-6 md:gap-8 px-4 absolute top-[120px] md:top-[150px] lg:top-[181px] left-0 right-0 lg:left-[calc(50%_-_390px)] lg:right-auto lg:w-[780px]">
        <header class="flex flex-col items-center gap-4 md:gap-5 w-full">
          <h1 class="[font-family:'Montserrat',Helvetica] font-semibold text-transparent text-3xl md:text-5xl lg:text-[65px] text-center tracking-[0] leading-[1.2] lg:leading-[78.7px]">
            <span class="text-[#fedf41]">Tour</span>
            <span class="text-[#f0f0f0]"> Our Facility</span>
          </h1>

          <p class="opacity-[0.99] [font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-lg lg:text-[22px] text-center tracking-[0] leading-[1.6] lg:leading-[35.2px] px-4 md:px-0">
            A private, premium fitness space designed for your success
          </p>
        </header>

        <button
          class="inline-flex items-center justify-center gap-2.5 px-6 md:px-[29px] py-3 bg-[#fedf41] rounded-[1000px] cursor-pointer transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#fedf41] focus:ring-offset-2 focus:ring-offset-transparent"
          type="button"
          onclick="window.location.href='/contact'"
          aria-label="Book In-Person Tour"
        >
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-black text-sm md:text-base tracking-[0] leading-[25.6px] whitespace-nowrap">
            Book In-Person Tour
          </span>

          <svg
            class="w-4 h-4"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M1.33333 2V14H13.3333V2H1.33333Z"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M1.33333 6H13.3333"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M10.6667 0V4M5.33333 0V4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      </section>
    </div>

    <!-- Main Content -->
    <div class="flex flex-col w-full items-center">
      <!-- Virtual Tour Section -->
      <section class="flex flex-col w-full max-w-[1200px] items-center gap-8 md:gap-12 px-4 md:px-8 py-12 md:py-16 mx-auto relative z-10">
        <header class="flex flex-col items-center gap-4 w-full">
          <div
            class="relative w-12 h-12 md:w-16 md:h-16"
            role="img"
            aria-label="Virtual tour icon"
          >
            <img
              class="absolute w-[83.33%] h-[66.67%] top-[12.50%] left-[4.17%]"
              alt=""
              src="/img/vector-6.svg"
            />

            <img
              class="absolute w-[25.00%] h-[25.00%] top-[37.50%] left-[33.33%]"
              alt=""
              src="/img/vector-7.svg"
            />
          </div>

          <div class="flex flex-col items-center gap-1.5 w-full">
            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-neutral-50 text-2xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]">
              Virtual Tour
            </h2>

            <p class="[font-family:'Montserrat',Helvetica] font-normal text-white text-sm md:text-base text-center tracking-[0] leading-7">
              Explore our facility from the comfort of your home
            </p>
          </div>
        </header>

        <div class="w-full bg-[#191919] overflow-hidden rounded-xl shadow-[0px_1px_2px_#0000000d]">
          <!-- Kuula 360° Virtual Tour Embed -->
          <iframe
            title="Ambition Fitness 360° Virtual Tour"
            width="100%"
            height="400"
            class="w-full h-[300px] md:h-[450px] lg:h-[575px] border-none rounded-xl"
            frameborder="0"
            allow="xr-spatial-tracking; gyroscope; accelerometer; fullscreen"
            scrolling="no"
            allowfullscreen="true"
            src="https://kuula.co/share/collection/7Y3kG?logo=1&info=1&fs=1&vr=0&sd=1&thumbs=1">
            <p>Your browser doesn't support iframes. <a href="https://kuula.co/share/collection/7Y3kG?logo=1&info=1&fs=1&vr=0&sd=1&thumbs=1" target="_blank" rel="noopener noreferrer">View the virtual tour directly on Kuula</a></p>
          </iframe>
        </div>
      </section>

      <!-- Facility Features Section with Grey Wave Background -->
      <div class="relative w-full">
        <!-- Grey Wave Background -->
        <img
          class="hidden lg:block absolute top-0 left-0 w-full h-full object-cover pointer-events-none"
          alt=""
          src="/img/union.svg"
        />

        <section class="flex flex-col w-full max-w-4xl items-center gap-8 md:gap-12 px-4 md:px-8 py-12 md:py-16 mx-auto relative z-10">
          <header class="flex flex-col items-center w-full">
            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-neutral-50 text-2xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]">
              Facility Features
            </h2>
          </header>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full">
            {facilityFeatures.map((feature) => (
              <div class="flex items-start gap-4 p-4 md:p-[25px] bg-black rounded-xl shadow-[0px_1px_2px_#0000000d]">
                <div class="flex flex-col w-6 h-7 items-start pt-1 pb-0 px-0">
                  <div class="relative w-6 h-6">
                    <img
                      class="absolute w-[66.67%] h-[45.83%] top-[20.83%] left-[12.50%]"
                      alt=""
                      src="/img/vector-15.svg"
                    />
                  </div>
                </div>
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-white text-sm md:text-base tracking-[0] leading-7">
                  {feature}
                </p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Facility Gallery Section with Carousel -->
      <section class="flex flex-col w-full max-w-[1400px] items-center gap-8 md:gap-12 px-4 md:px-8 py-12 md:py-16 mx-auto">
        <header class="flex flex-col items-center w-full">
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-neutral-50 text-2xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]">
            Facility Gallery
          </h2>
        </header>

        <!-- Image Carousel -->
        <div class="relative w-full max-w-[1200px]">
          <div class="carousel-container relative w-full">
            <!-- Main Image Display -->
            <div class="carousel-viewport relative w-full h-[250px] md:h-[400px] lg:h-[600px] bg-black rounded-xl overflow-hidden">
              <ul id="carousel-track" class="carousel-track flex transition-transform duration-500 ease-in-out h-full">
                {galleryImages.map((image) => (
                  <li class="carousel-slide min-w-full h-full flex-shrink-0">
                    <img src={image.src} alt={image.alt} class="w-full h-full object-cover" />
                  </li>
                ))}
              </ul>

              <!-- Navigation Arrows -->
              <button id="carousel-prev" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-2 md:p-3 rounded-full transition-all z-10">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 md:w-7 md:h-7">
                  <path fill-rule="evenodd" d="M15.485 4L7 11.769l.499.484-.002.001L15.463 20l1.48-1.394-6.984-6.794 6.963-6.375z"></path>
                </svg>
              </button>
              <button id="carousel-next" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-2 md:p-3 rounded-full transition-all z-10">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 md:w-7 md:h-7">
                  <path fill-rule="evenodd" d="M8.515 4L17 11.769l-.499.484.002.001L8.537 20l-1.48-1.394 6.984-6.794-6.963-6.375z"></path>
                </svg>
              </button>
            </div>

            <!-- Thumbnail Navigation -->
            <div class="mt-4 overflow-x-auto overflow-y-hidden">
              <ul id="thumbnail-nav" class="flex gap-2 justify-start md:justify-center pb-2">
                {galleryImages.map((image, index) => (
                  <li class={`thumbnail-item ${index === 0 ? 'opacity-100' : 'opacity-60 hover:opacity-100'} transition-opacity cursor-pointer flex-shrink-0`}>
                    <img src={image.thumb} alt={`Thumbnail ${index + 1}`} class={`w-[50px] h-[50px] md:w-[70px] md:h-[70px] object-cover rounded border-2 ${index === 0 ? 'border-[#fedf41]' : 'border-transparent hover:border-[#fedf41]'}`} />
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- What Makes Us Different Section with Grey Wave Background -->
      <div class="relative w-full">
        <!-- Grey Wave Background -->
        <img
          class="hidden lg:block absolute top-0 left-0 w-full h-full object-cover pointer-events-none"
          alt=""
          src="/img/union-1.svg"
        />

        <section class="flex flex-col w-full max-w-[1196px] items-center gap-8 md:gap-12 px-4 md:px-8 py-12 md:py-16 mx-auto relative z-10">
          <header class="flex flex-col items-center w-full">
            <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-neutral-50 text-2xl md:text-4xl lg:text-[45px] text-center tracking-[0] leading-[1.3] lg:leading-[60px]">
              What Makes Us Different
            </h2>
          </header>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-[30px] w-full">
            {differentiators.map((item) => (
              <article class="flex flex-col items-start gap-1.5 p-6 md:p-[33px] bg-black rounded-xl shadow-[0px_1px_2px_#0000000d]">
                <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-xl md:text-2xl tracking-[0] leading-10">
                  {item.title}
                </h3>
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#eeeeee] text-sm md:text-base tracking-[0] leading-7">
                  {item.description}
                </p>
              </article>
            ))}
