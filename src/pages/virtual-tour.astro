                <li class="carousel-slide min-w-full h-full flex-shrink-0">
                  <img src="//img1.wsimg.com/isteam/ip/6a30f4a0-7267-4714-8260-f9482ecd1f55/1-0001.jpg/:/rs=w:1280,h:853" alt="Gym Entrance" class="w-full h-full object-cover" />
