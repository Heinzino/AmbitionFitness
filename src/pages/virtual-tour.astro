    <script>
      // Mobile Menu Toggle
      document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerLines = document.querySelectorAll('.hamburger-line');

        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', function() {
            const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';

            mobileMenuBtn.setAttribute('aria-expanded', !isExpanded);
            mobileMenu.classList.toggle('hidden');

            // Animate hamburger to X
            if (!isExpanded) {
              hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
              hamburgerLines[1].style.opacity = '0';
              hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';
            } else {
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
            }
          });
        }

        // Carousel functionality
        const track = document.getElementById('carousel-track');
        const slides = track?.querySelectorAll('.carousel-slide');
        const prevButton = document.getElementById('carousel-prev');
        const nextButton = document.getElementById('carousel-next');
        const thumbnails = document.querySelectorAll('.thumbnail-item');

        let currentIndex = 0;
        const totalSlides = slides?.length || 0;
        let autoPlayInterval;

        function updateCarousel() {
          if (track) {
            track.style.transform = `translateX(-${currentIndex * 100}%)`;
          }

          // Update thumbnail active states
          thumbnails.forEach((thumb, index) => {
            const img = thumb.querySelector('img');
            if (index === currentIndex) {
              thumb.classList.remove('opacity-60');
              thumb.classList.add('opacity-100');
              img?.classList.remove('border-transparent', 'border-white/20');
              img?.classList.add('border-[#fedf41]', 'scale-105');
              if (img) img.style.transition = 'all 0.3s ease';
            } else {
              thumb.classList.add('opacity-60');
              thumb.classList.remove('opacity-100');
              img?.classList.add('border-transparent');
              img?.classList.remove('border-[#fedf41]', 'scale-105');
              img?.classList.add('border-white/20');
              if (img) img.style.transition = 'all 0.3s ease';
            }
          });
        }

        function nextSlide() {
          currentIndex = (currentIndex + 1) % totalSlides;
          updateCarousel();
        }

        function prevSlide() {
          currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
          updateCarousel();
        }

        function resetAutoPlay() {
          if (autoPlayInterval) {
            clearInterval(autoPlayInterval);
          }
          autoPlayInterval = setInterval(nextSlide, 11000);
        }

        // Event listeners
        nextButton?.addEventListener('click', () => {
          nextSlide();
          resetAutoPlay();
        });

        prevButton?.addEventListener('click', () => {
          prevSlide();
          resetAutoPlay();
        });

        // Thumbnail click handlers
        thumbnails.forEach((thumb, index) => {
          thumb.addEventListener('click', () => {
            currentIndex = index;
            updateCarousel();
            resetAutoPlay();
          });

          thumb.addEventListener('mouseenter', () => {
            if (index !== currentIndex) {
              thumb.classList.remove('opacity-60');
              thumb.classList.add('opacity-80');
            }
          });

          thumb.addEventListener('mouseleave', () => {
            if (index !== currentIndex) {
              thumb.classList.remove('opacity-80');
              thumb.classList.add('opacity-60');
            }
          });
        });

        // Initialize carousel
        updateCarousel();
        resetAutoPlay();

        // Pause auto-play on hover
        const carouselContainer = document.querySelector('.carousel-viewport');
        carouselContainer?.addEventListener('mouseenter', () => {
          clearInterval(autoPlayInterval);
        });

        carouselContainer?.addEventListener('mouseleave', () => {
          resetAutoPlay();
        });
      });
    </script>
