---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const pageTitle = "Personal Trainer Mayland Heights Calgary | Your Neighborhood Gym | Ambition Fitness";
const pageDescription = "Personal training in Mayland Heights Calgary. Located right in your neighborhood at 1440 52 St NE. Certified trainers, private facility, proven results. Book your free consultation.";
const neighborhood = "Mayland Heights";

const navigationLinks = [
  { label: "Home", path: "/", isActive: false },
  { label: "Personal Training", path: "/personal-training", isActive: false },
  { label: "Memberships", path: "/memberships", isActive: false },
  { label: "Group Sessions", path: "/group-sessions", isActive: false },
  { label: "Virtual Tour", path: "/virtual-tour", isActive: false },
];

const localBenefits = [
  {
    title: "Right in Your Neighborhood",
    description: "Located at 1440 52 St NE in Mayland Heights. No long commute—your personal training facility is right here in your community.",
  },
  {
    title: "Private Training Environment",
    description: "Train in a comfortable, private facility—not a crowded commercial gym. Personal attention from certified trainers who know your name.",
  },
  {
    title: "Convenient Scheduling",
    description: "Early morning, lunch, evening, and weekend sessions available. Easy to fit training into your busy schedule when we're just minutes away.",
  },
  {
    title: "Community-Focused",
    description: "We're your neighborhood gym. Join other Mayland Heights residents who have made Ambition Fitness their fitness home.",
  },
];

const services = [
  { name: "1-on-1 Personal Training", link: "/personal-training" },
  { name: "Weight Loss Programs", link: "/weight-loss-personal-trainer-calgary" },
  { name: "Strength Training", link: "/strength-training-calgary" },
  { name: "Body Transformation", link: "/body-transformation-calgary" },
  { name: "Group Sessions", link: "/group-sessions" },
  { name: "Gym Memberships", link: "/memberships" },
];

const faqData = [
  {
    question: "Where exactly in Mayland Heights are you located?",
    answer: "We're located at 1440 52 St NE #130, in the heart of Mayland Heights. Easy access from 16 Ave NE and Memorial Drive. Free parking available on-site.",
  },
  {
    question: "What makes you different from big box gyms?",
    answer: "We're a private personal training facility—not a commercial gym. You get personalized attention, expert coaching, and a supportive environment without the crowds, wait times, or intimidation factor of large gyms.",
  },
  {
    question: "Do you offer any special rates for Mayland Heights residents?",
    answer: "Contact us for a free consultation and we'll discuss package options that fit your goals and budget. We love serving our local community!",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/img/AF_Logo_White.png" />
    <SEO title={pageTitle} description={pageDescription} canonical="/personal-trainer-mayland-heights-calgary" />
    <LocalBusinessSchema />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Montserrat:wght@400;500;600;700&family=Prompt:wght@500&display=swap" /></noscript>
    <style>
      html { scroll-behavior: smooth; }
      body { overflow-x: hidden; overflow-y: auto; }
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Hero Section -->
    <div class="relative w-full h-[450px] md:h-[550px] lg:h-[600px]">
      <img class="absolute top-0 left-0 w-full h-full object-cover" alt="Personal Trainer Mayland Heights Calgary" src="/img/rectangle-6542.png" />

      <!-- Navigation -->
      <nav class="absolute top-0 left-0 w-full z-50">
        <div class="flex items-center justify-between px-4 md:px-8 lg:px-0 py-4 lg:py-0 lg:relative lg:inline-flex lg:gap-[221px] lg:top-[15px] lg:left-[360px] lg:w-auto">
          <a href="/"><img class="w-16 md:w-20 lg:w-[95px] h-auto aspect-[0.93] object-cover relative z-50" alt="Ambition Fitness Logo" src="/img/image-3-2.png" /></a>
          <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-0 cursor-pointer z-50 relative" aria-label="Toggle mobile menu" aria-expanded="false">
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white mb-1.5 transition-all duration-300"></span>
            <span class="hamburger-line block w-7 h-0.5 bg-white transition-all duration-300"></span>
          </button>
          <div class="hidden md:flex items-center justify-end gap-4 md:gap-6 lg:gap-10 w-full lg:w-auto relative lg:flex-[0_0_auto]">
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 lg:gap-[30px] items-center relative lg:inline-flex lg:flex-[0_0_auto]">
              {navigationLinks.map((link) => (
                <a class={`relative flex items-center justify-center w-fit [font-family:'Inter',Helvetica] font-medium text-sm lg:text-lg text-center tracking-[0] leading-[27px] whitespace-nowrap ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`} href={link.path}>{link.label}</a>
              ))}
            </div>
            <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-4 md:px-[23px] py-3 md:py-[15.49px] relative flex-[0_0_auto] bg-variable-collection-coloryellow rounded-[12.39px] w-full md:w-auto hover:opacity-90 transition-opacity">
              <span class="relative flex items-center justify-center w-fit font-16-medium text-variable-collection-colorpriamry text-center whitespace-nowrap">Get in Touch</span>
              <img class="relative w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
            </a>
          </div>
        </div>
        <div id="mobile-menu" class="fixed inset-0 bg-black bg-opacity-95 z-40 hidden md:hidden">
          <div class="flex flex-col items-center justify-center h-full px-4">
            <div class="flex flex-col items-center gap-8 w-full max-w-sm">
              {navigationLinks.map((link) => (
                <a class={`text-2xl font-semibold [font-family:'Inter',Helvetica] ${link.isActive ? 'text-variable-collection-coloryellow' : 'text-white hover:text-variable-collection-coloryellow transition-colors'}`} href={link.path}>{link.label}</a>
              ))}
              <a href="/contact" class="inline-flex items-center justify-center gap-[10.33px] px-8 py-4 bg-variable-collection-coloryellow rounded-[12.39px] mt-4 hover:opacity-90 transition-opacity">
                <span class="font-semibold text-variable-collection-colorpriamry text-lg [font-family:'Inter',Helvetica]">Get in Touch</span>
                <img class="w-[18.33px] h-[11.41px]" alt="Arrow" src="/img/line-108-3.svg" />
              </a>
            </div>
          </div>
        </div>
      </nav>

      <!-- Hero Content -->
      <section class="absolute top-[55%] md:top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 flex flex-col w-full max-w-[90%] md:max-w-[750px] items-center justify-center gap-6 px-6 md:px-[50px] py-8 md:py-[40px] bg-[#0000000f] rounded-xl backdrop-blur-[17px]">
        <h1 class="[font-family:'Montserrat',Helvetica] font-semibold text-transparent text-2xl md:text-4xl lg:text-[50px] text-center leading-tight md:leading-[1.2]">
          <span class="text-[#f0f0f0]">Your </span>
          <span class="text-[#fedf41]">{neighborhood}</span>
          <span class="text-[#f0f0f0]"> Personal Trainer</span>
        </h1>
        <p class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base md:text-lg lg:text-xl text-center leading-relaxed max-w-xl">
          Right here in your neighborhood. Certified personal trainers, private facility, and proven results—without the long commute.
        </p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2.5 px-6 md:px-8 py-3 md:py-4 bg-variable-collection-coloryellow rounded-full hover:opacity-90 transition-all hover:scale-105">
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-variable-collection-colorpriamry text-sm md:text-base">Book Free Consultation</span>
          <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-3.svg" />
        </a>
      </section>
    </div>

    <!-- Main Content -->
    <main class="flex flex-col w-full items-center">
      <!-- Location Benefits -->
      <section class="flex flex-col w-full max-w-[1100px] items-center gap-12 px-4 md:px-8 py-16 md:py-20 mx-auto">
        <header class="flex flex-col items-center gap-4 text-center">
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[35px] tracking-[0] leading-tight">
            Why Mayland Heights Chooses Ambition Fitness
          </h2>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 w-full">
          {localBenefits.map((benefit) => (
            <article class="flex items-start gap-4 p-6 bg-[#191919] rounded-xl border border-[#2e2e2e]">
              <div class="flex-shrink-0 w-3 h-3 mt-2 bg-variable-collection-coloryellow rounded-full" />
              <div>
                <h3 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-lg mb-2">{benefit.title}</h3>
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base leading-relaxed">{benefit.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Services -->
      <section class="flex flex-col w-full max-w-[1100px] items-center gap-8 px-4 md:px-8 py-12 mx-auto">
        <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[30px] text-center">Our Services</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 w-full">
          {services.map((service) => (
            <a href={service.link} class="p-4 bg-[#191919] rounded-lg border border-[#2e2e2e] hover:border-variable-collection-coloryellow transition-colors text-center">
              <span class="[font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base">{service.name}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Location Info -->
      <section class="flex flex-col w-full max-w-[1100px] items-center gap-8 px-4 md:px-8 py-12 mx-auto">
        <div class="w-full p-8 bg-[#191919] rounded-xl border border-[#2e2e2e]">
          <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-xl md:text-2xl mb-4">Visit Us in Mayland Heights</h2>
          <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base mb-4">
            <strong class="text-white">Address:</strong> 1440 52 St NE #130, Calgary, AB T2A 4T8
          </p>
          <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base mb-4">
            <strong class="text-white">Location:</strong> In the Mayland Heights area, easy access from 16 Ave NE, Memorial Drive, and Deerfoot Trail.
          </p>
          <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-base">
            <strong class="text-white">Parking:</strong> Free parking available on-site.
          </p>
        </div>
      </section>

      <!-- FAQ -->
      <section class="flex flex-col w-full max-w-[800px] items-center gap-8 px-4 md:px-8 py-12 mx-auto">
        <h2 class="[font-family:'Montserrat',Helvetica] font-semibold text-white text-2xl md:text-[30px]">FAQ</h2>
        <div class="flex flex-col gap-4 w-full">
          {faqData.map((faq) => (
            <details class="group bg-[#191919] rounded-xl border border-[#2e2e2e] overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="[font-family:'Montserrat',Helvetica] font-medium text-white text-base text-left">{faq.question}</h3>
                <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-variable-collection-coloryellow transition-transform group-open:rotate-45">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </span>
              </summary>
              <div class="px-5 pb-5">
                <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#e4e4e4] text-sm leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="flex flex-col w-full max-w-[900px] items-center justify-center gap-6 p-8 md:p-12 mx-4 md:mx-auto mb-12 bg-variable-collection-coloryellow rounded-xl">
        <h2 class="[font-family:'Prompt',Helvetica] font-medium text-variable-collection-colorpriamry text-2xl md:text-4xl text-center">Your Neighborhood Gym Awaits</h2>
        <p class="[font-family:'Montserrat',Helvetica] font-normal text-[#222222] text-base md:text-lg text-center max-w-xl">
          Join your Mayland Heights neighbors who train at Ambition Fitness. Book your free consultation today.
        </p>
        <a href="/contact" class="inline-flex h-12 items-center justify-center gap-3 px-6 py-4 bg-variable-collection-colorpriamry rounded-xl hover:opacity-90 transition-opacity">
          <span class="[font-family:'Montserrat',Helvetica] font-medium text-white text-sm md:text-base">Book Free Consultation</span>
          <img class="w-[18px] h-[11px]" alt="" src="/img/line-108-white.svg" />
        </a>
      </section>
    </main>

    <!-- Footer -->
    <footer class="w-full pt-12 pb-8 px-4 md:px-8 bg-black">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-1">
            <img class="w-[50px] md:w-[63px] h-auto mb-4" alt="Ambition Fitness Logo" src="/img/image-3-2-1.png" />
            <p class="text-[#e4e4e4] text-sm">Calgary's trusted personal training facility.</p>
          </div>
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Services</h3>
            <div class="space-y-2">
              <a href="/personal-training" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Personal Training</a>
              <a href="/memberships" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Memberships</a>
              <a href="/group-sessions" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Group Sessions</a>
            </div>
          </div>
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Service Area</h3>
            <div class="space-y-2">
              <a href="/personal-trainer-mayland-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Mayland Heights</a>
              <a href="/personal-trainer-meridian-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Meridian</a>
              <a href="/personal-trainer-raddison-heights-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Raddison Heights</a>
              <a href="/personal-trainer-bridgeland-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Bridgeland-Riverside</a>
              <a href="/personal-trainer-renfrew-calgary" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Renfrew</a>
            </div>
          </div>
          <div>
            <h3 class="text-variable-collection-coloryellow font-semibold mb-4">Company</h3>
            <div class="space-y-2">
              <a href="/" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Home</a>
              <a href="/blog" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Blog</a>
              <a href="/contact" class="block text-[#e4e4e4] text-sm hover:text-variable-collection-coloryellow">Contact Us</a>
            </div>
          </div>
        </div>
        <div class="pt-8 border-t border-gray-700 flex justify-between items-center">
          <p class="text-[#919191] text-sm">© 2025 Ambition Fitness · All rights reserved.</p>
          <a href="https://www.instagram.com/ambitionfitness.ca" target="_blank" rel="noopener noreferrer">
            <img class="w-8 h-8" alt="Instagram" src="/img/instagram-icon.svg" />
          </a>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerLines = document.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;
        let isMenuOpen = false;
        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', function() {
            isMenuOpen = !isMenuOpen;
            if (isMenuOpen) {
              mobileMenu.classList.remove('hidden');
              document.body.style.overflow = 'hidden';
              hamburgerLines[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
              hamburgerLines[1].style.opacity = '0';
              hamburgerLines[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';
            } else {
              mobileMenu.classList.add('hidden');
              document.body.style.overflow = '';
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
            }
          });
          mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', function() {
              mobileMenu.classList.add('hidden');
              document.body.style.overflow = '';
              hamburgerLines[0].style.transform = '';
              hamburgerLines[1].style.opacity = '1';
              hamburgerLines[2].style.transform = '';
            });
          });
        }
      });
    </script>
  </body>
</html>
